---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Palette preview — dark/light toggle, accent gradient, brand swatches,
// Material You roles, ANSI 16.  Every grid is rendered at build time
// (the dark and light variants are both emitted, with CSS hiding the
// inactive one via [data-palette-theme]).  Theme toggle only has to
// swap the stylesheet link and flip the root data-attribute.
//
// The theme stylesheets live under /public/palette/ (preview.css,
// preview.dark.css, preview.light.css) — src/scripts/palette.ts
// rewrites the <link href="…"> at runtime and expects them served
// from the /palette/ origin.

import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PhosphorLogoDark from "../../components/PhosphorLogoDark.astro";
import PhosphorLogoLight from "../../components/PhosphorLogoLight.astro";
import {
    BRAND,
    ROLE_ORDER,
    ROLES_DARK,
    ROLES_LIGHT,
    ANSI,
    onColor,
    type Theme,
    type RoleMap,
} from "../../data/palette";

// Render helpers that pre-compute the on-color + hex lookups once at
// build time.  The template below just iterates the results; no logic
// inline.
type SwatchRow = {
    name: string; desc: string; hex: string; alias: string; on: string;
};
const brandFor = (theme: Theme): SwatchRow[] =>
    BRAND.map(b => ({
        name: b.name,
        desc: b.desc,
        hex: b[theme].hex,
        alias: b[theme].alias,
        on: onColor(b[theme].hex),
    }));

type RoleRow = { key: string; hex: string };
const rolesFor = (roles: RoleMap): RoleRow[] =>
    ROLE_ORDER.filter(k => roles[k]).map(k => ({ key: k, hex: roles[k]! }));

const brandDark  = brandFor("dark");
const brandLight = brandFor("light");
const rolesDark  = rolesFor(ROLES_DARK);
const rolesLight = rolesFor(ROLES_LIGHT);
const ansi       = ANSI.map(c => ({ ...c, on: onColor(c.hex) }));
---

<BaseLayout title="Phosphor — PlasmaZones Palette">
    <link slot="head" rel="stylesheet" href="/palette/preview.css" />
    <link slot="head" rel="stylesheet" href="/palette/preview.dark.css" id="theme-link" />

    <Topbar crumb="Brand Palette" current="palette" />

    <main id="main" class="container">

        <div class="hero">
            <div class="theme-toggle">
                <button data-theme-btn="dark" class="active">Dark</button>
                <button data-theme-btn="light">Light</button>
            </div>
            <div class="hero-inner">
                <PhosphorLogoDark class="hero-logo" />
                <PhosphorLogoLight />
                <div class="hero-text">
                    <h1>Phosphor</h1>
                    <p>PlasmaZones brand palette — cyan → blue → purple → rose on deep navy.</p>
                    <div class="meta">
                        <span><span class="dot"></span>v1.0</span>
                        <span>data/palettes/phosphor.toml</span>
                        <span>Material You + ANSI 16 + matugen bridge</span>
                    </div>
                </div>
            </div>
        </div>

        <section>
            <h2>Accent Gradient <small>cyan → blue → purple → rose, theme-adapted</small></h2>
            <div class="gradient-bar">
                <div class="stops" data-variant="dark">
                    {brandDark.slice(0, 4).map(c => <span>{c.hex}</span>)}
                </div>
                <div class="stops" data-variant="light">
                    {brandLight.slice(0, 4).map(c => <span>{c.hex}</span>)}
                </div>
            </div>
        </section>

        <section>
            <h2>Brand <small>7 canonical colors from the SVG gradient stops</small></h2>
            <div class="grid" data-variant="dark">
                {brandDark.map(c => (
                    <div class="swatch" style={`background:${c.hex}; color:${c.on}`} data-hex={c.hex}>
                        <div>
                            <div class="label">{c.name}</div>
                            <div class="alias">{c.desc}</div>
                        </div>
                        <div>
                            <div class="hex">{c.hex}</div>
                            <div class="alias" style="font-size:10px">{c.alias}</div>
                        </div>
                    </div>
                ))}
            </div>
            <div class="grid" data-variant="light">
                {brandLight.map(c => (
                    <div class="swatch" style={`background:${c.hex}; color:${c.on}`} data-hex={c.hex}>
                        <div>
                            <div class="label">{c.name}</div>
                            <div class="alias">{c.desc}</div>
                        </div>
                        <div>
                            <div class="hex">{c.hex}</div>
                            <div class="alias" style="font-size:10px">{c.alias}</div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <section>
            <h2>Zones <small>alpha-composited plasmazones roles</small></h2>
            <div class="zone-preview">
                <div class="zone active">Active Zone</div>
                <div class="zone dormant">Dormant</div>
                <div class="zone dormant">Dormant</div>
                <div class="zone active">Active Zone</div>
            </div>
        </section>

        <section>
            <h2>Material You <small>role map — hover to copy, click to copy</small></h2>
            <div class="roles" data-variant="dark">
                {rolesDark.map(r => (
                    <div class="role" data-hex={r.hex}>
                        <div class="role-chip" style={`background:${r.hex}`}></div>
                        <div class="role-body">
                            <div class="role-name">{r.key}</div>
                            <div class="role-hex">{r.hex.toUpperCase()}</div>
                        </div>
                    </div>
                ))}
            </div>
            <div class="roles" data-variant="light">
                {rolesLight.map(r => (
                    <div class="role" data-hex={r.hex}>
                        <div class="role-chip" style={`background:${r.hex}`}></div>
                        <div class="role-body">
                            <div class="role-name">{r.key}</div>
                            <div class="role-hex">{r.hex.toUpperCase()}</div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <section>
            <h2>ANSI 16 <small>pywal / base16 terminal compatibility</small></h2>
            <div class="ansi-grid">
                {ansi.map(c => (
                    <div class="ansi-cell"
                         style={`background:${c.hex}; color:${c.on}`}
                         data-hex={c.hex}
                         title={`${c.label} — ${c.alias}`}>
                        <div class="ansi-index">{c.i}</div>
                        <div class="ansi-body">
                            <div class="ansi-label">{c.label}</div>
                            <div class="ansi-hex">{c.hex}</div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <footer>
            Phosphor palette v1.0 — derived from the PlasmaZones logo gradient stops.
            Source TOML: <a href="/palette/phosphor.toml">phosphor.toml</a>.
            Matugen template lives upstream in
            <a href="https://github.com/fuddlesworth/PlasmaZones/tree/main/data/matugen">PlasmaZones</a>.
            Back to <a href="/">home</a>.
        </footer>
    </main>

    <script>
        import "../../scripts/palette";
    </script>

    <style is:global>
        /* Theme-variant toggle.  Both dark and light content sets are
           SSR-rendered into the DOM; CSS hides whichever isn't active
           by reading :root[data-theme] — same attribute the rest of
           the site uses, so the palette stays in sync with the topbar
           ThemeToggle without any JS coordination. */
        :root[data-theme="dark"]  [data-variant="light"] { display: none; }
        :root[data-theme="light"] [data-variant="dark"]  { display: none; }
    </style>
</BaseLayout>
