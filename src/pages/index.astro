---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later

import BaseLayout from "../layouts/BaseLayout.astro";
import HeroLogoDark from "../components/HeroLogoDark.astro";
import { LIBRARIES } from "../data/libraries";
import "../styles/home.css";
---

<BaseLayout
    title="Phosphor — Qt6 / Wayland library suite"
    description="Phosphor: a suite of Qt6 / Wayland libraries for building window-management tools."
>
    <main class="container">

        <!-- ═══════════════ Hero ═══════════════ -->
        <header class="hero">
            <HeroLogoDark class="logo" />
            <div class="hero-text">
                <h1>Phosphor</h1>
                <p class="tagline">Qt6 and Wayland libraries for window-management tools.</p>
                <p class="blurb">
                    Zones, layers, layout algorithms, shader effects, global
                    shortcuts. Packaged as focused LGPL libraries. Built for
                    KDE Plasma, usable from any Wayland compositor or Qt host.
                </p>
            </div>
        </header>

        <!-- ═══════════════ Libraries ═══════════════ -->
        <section>
            <h2>The Suite</h2>
            <p class="muted">
                Ten libraries, each with a single responsibility. Per-library
                docs are still being written. The source currently lives in
                the <a href="https://github.com/fuddlesworth/PlasmaZones">PlasmaZones repository</a>.
            </p>
            <ul class="libs">
                {LIBRARIES.map(lib => (
                    <li>
                        <a href={`/libraries/${lib.slug}/`}>
                            <code>{`phosphor-${lib.slug}`}</code>
                            <span>{lib.oneLiner}</span>
                        </a>
                    </li>
                ))}
            </ul>
        </section>

        <!-- ═══════════════ Resources ═══════════════ -->
        <section>
            <h2>Resources</h2>
            <ul class="links">
                <li>
                    <a href="/libraries/">Libraries</a>
                    <span class="muted">Per-library overview pages with a jump-off to the full API.</span>
                </li>
                <li>
                    <a href="/api/">API Reference</a>
                    <span class="muted">Doxygen-generated docs for every header under <code>libs/phosphor-*/include/</code>.</span>
                </li>
                <li>
                    <a href="/brand/">Brand assets</a>
                    <span class="muted">Logos, icon variants, and color tokens. CC-BY-SA 4.0.</span>
                </li>
                <li>
                    <a href="/palette/">Brand palette</a>
                    <span class="muted">Material You roles, ANSI 16 mapping, and the matugen template. Click any swatch to copy.</span>
                </li>
                <li>
                    <a href="https://github.com/phosphor-works">phosphor-works on GitHub</a>
                    <span class="muted">Organization hosting the branding and website. Individual libraries land here soon.</span>
                </li>
            </ul>
        </section>

        <footer>
            <span>© 2026 fuddlesworth · GPL-3.0-or-later</span>
            <a href="https://github.com/phosphor-works">github.com/phosphor-works</a>
        </footer>

    </main>
</BaseLayout>
