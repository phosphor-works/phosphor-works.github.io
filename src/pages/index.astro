// SPDX-License-Identifier: GPL-3.0-or-later

import BaseLayout from "../layouts/BaseLayout.astro";
import PhosphorLogoDark from "../components/PhosphorLogoDark.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { LIBRARIES } from "../data/libraries";
import "../styles/home.css";

const libCount = LIBRARIES.length;
---

<BaseLayout
    title="Phosphor — Qt6 / Wayland library suite"
    description="Phosphor: a suite of Qt6 / Wayland libraries for building window-management tools."
>
    <main class="container">

        <!-- ═══════════════ Hero ═══════════════ -->
        <header class="hero gradient-overlay">
            <PhosphorLogoDark class="logo" />
            <div class="hero-text">
                <h1>Phosphor</h1>
                <p class="tagline">Qt6 and Wayland libraries for window-management tools.</p>
                <p class="blurb">
                    Zones, layers, layout algorithms, shader effects, global
                    shortcuts. Packaged as focused LGPL libraries. Built for
                    KDE Plasma, usable from any Wayland compositor or Qt host.
                </p>
            </div>
        </header>

        <!-- ═══════════════ Flagship ═══════════════ -->
        <section class="flagship">
            <a class="flagship-card gradient-overlay" href="/plasmazones/">
                <div class="flagship-tag">Flagship app</div>
                <h2 class="flagship-title">PlasmaZones</h2>
                <p>Zone-based window tiling for KDE Plasma. The first consumer built on this library suite.</p>
                <span class="flagship-cta">Explore PlasmaZones →</span>
            </a>
        </section>

        <!-- ═══════════════ Libraries ═══════════════ -->
        <section>
            <div class="section-head">
                <h2>Libraries</h2>
                <a class="section-all" href="/libraries/">Library index →</a>
            </div>
            <p class="muted">
                {libCount} libraries, each with a single responsibility. Click any
                card for a one-page overview and a link into the full API.
            </p>
            <ul class="libs">
                {LIBRARIES.map(lib => (
                    <li>
                        <a href={`/libraries/${lib.slug}/`}>
                            <code>{`phosphor-${lib.slug}`}</code>
                            <span>{lib.oneLiner}</span>
                        </a>
                    </li>
                ))}
            </ul>
        </section>

        <!-- ═══════════════ Learn ═══════════════ -->
        <section>
            <h2>Learn</h2>
            <div class="card-row">
                <a class="card" href="/guides/">
                    <h3>Guides</h3>
                    <p>Authoring contracts for custom GLSL shaders and JavaScript tiling algorithms.</p>
                </a>
                <a class="card" href="/api/">
                    <h3>API Reference</h3>
                    <p>Doxygen-generated docs for every header under <code>libs/phosphor-*/include/</code>.</p>
                </a>
            </div>
        </section>

        <!-- ═══════════════ Design ═══════════════ -->
        <section>
            <h2>Design</h2>
            <div class="card-row">
                <a class="card" href="/brand/">
                    <h3>Brand assets</h3>
                    <p>Logos, icon variants, and color tokens. CC-BY-SA 4.0 so they travel into docs and release notes cleanly.</p>
                </a>
                <a class="card" href="/palette/">
                    <h3>Brand palette</h3>
                    <p>Material You roles, ANSI 16 terminal mapping, and a matugen template. Click any swatch to copy.</p>
                </a>
            </div>
        </section>

        <SiteFooter>
            <Fragment slot="right">
                <span>
                    <a href="/about/">About</a>
                    ·
                    <a href="https://github.com/phosphor-works">github.com/phosphor-works</a>
                </span>
            </Fragment>
        </SiteFooter>

    </main>
</BaseLayout>
