import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import "../../styles/home.css";

const GUIDES = [
    {
        href: "/guides/shaders/",
        title: "Shader authoring",
        blurb: "Write custom GLSL shaders for zone overlays. Uniform contract, " +
               "metadata schema, audio reactivity, multipass.",
    },
    {
        href: "/guides/tiling/",
        title: "Tiling algorithms",
        blurb: "Author custom tiling algorithms in JavaScript. Sandbox contract, " +
               "built-in helpers, hot-reload.",
    },
];
---

<BaseLayout title="Phosphor — Guides" description="Authoring guides for Phosphor shaders, tiling algorithms, and more.">
    <Topbar crumb="Guides" current="guides" />

    <main id="main" class="container guides-index">

        <PageHero
            title="Guides"
            tagline="Authoring guides for the pluggable extension points of Phosphor and PlasmaZones."
        />

        <ul class="links">
            {GUIDES.map(g => (
                <li>
                    <a href={g.href}>{g.title} →</a>
                    <span class="muted">{g.blurb}</span>
                </li>
            ))}
        </ul>

        <SiteFooter note="Guides · GPL-3.0-or-later" />
    </main>
</BaseLayout>

<style>
    .guides-index { padding-top: 40px; }
</style>
