---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// API Reference landing — sits at /api/ and sends readers into the
// Doxygen-generated tree under /api/html/.  The Doxyfile's own header
// has a sticky Phosphor topbar on every generated page, so this
// landing just offers four shortcuts (full reference, classes,
// namespaces, files) and a library list.

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Card from "../../components/Card.astro";
import CardGrid from "../../components/CardGrid.astro";
import { LIBRARIES } from "../../data/libraries";
import "../../styles/home.css";

const libs = [...LIBRARIES].sort((a, b) => a.slug.localeCompare(b.slug));
---

<BaseLayout
    title="Phosphor — API Reference"
    description="Doxygen-generated public-header reference for the Phosphor library suite."
>
    <main id="main" class="container api-landing">

        <PageHero
            title="API Reference"
            tagline="Doxygen-generated public-header reference for the Phosphor library suite."
        />

        <section>
            <h2>Browse</h2>
            <ul class="links">
                <li>
                    <a href="/api/html/index.html"><b>Full reference</b> →</a>
                    <span class="muted">Main entry point. Class list, namespaces, file index, and search.</span>
                </li>
                <li>
                    <a href="/api/html/annotated.html">Classes</a>
                    <span class="muted">Alphabetical class and struct index across all libraries.</span>
                </li>
                <li>
                    <a href="/api/html/namespaces.html">Namespaces</a>
                    <span class="muted">One entry per <code>Phosphor*</code> library namespace.</span>
                </li>
                <li>
                    <a href="/api/html/files.html">Files</a>
                    <span class="muted">Every header under <code>libs/phosphor-*/include/</code>.</span>
                </li>
            </ul>
        </section>

        <section>
            <h2>Libraries covered</h2>
            <p class="lede">
                One Doxygen run across every library in the suite.  Each
                library's symbols live under its own namespace and
                directory in the generated tree.
            </p>
            <CardGrid min="240px" gap="var(--space-2)">
                {libs.map(lib => (
                    <Card href={`/libraries/${lib.slug}/`} padding="var(--space-3) var(--space-4)">
                        <code slot="title">phosphor-{lib.slug}</code>
                    </Card>
                ))}
            </CardGrid>
        </section>

        </main>
</BaseLayout>

<style>
    /* The API landing is tighter than the home landing so the four
       Browse shortcuts sit above the fold. */
    .api-landing { padding-top: var(--space-8); }
</style>
