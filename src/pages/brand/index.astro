---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// /brand/ — downloadable logo/icon showcase.  SVGs are served from
// /brand/assets/{dark,light}/ (a symlink in public/ pointing at
// submodules/branding/svg/ — single source of truth).  Three icon
// families (main, editor, settings) × two themes (dark, light).

import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import "../../styles/home.css";

const ICONS = [
    {
        slug: "phosphor",
        label: "Phosphor",
        desc: "Umbrella brand mark. Φ is the scientific symbol for luminous flux and visually reads as stylized \"P\"/\"ph\".",
    },
    {
        slug: "plasmazones",
        label: "PlasmaZones",
        desc: "Primary app icon for the zone-tiling flagship. Five stroked zones sitting inside the shared gradient frame.",
    },
    {
        slug: "plasmazones-editor",
        label: "PlasmaZones Editor",
        desc: "Layout editor variant. Zone motif wrapped in a canvas mark.",
    },
    {
        slug: "plasmazones-settings",
        label: "PlasmaZones Settings",
        desc: "Settings app variant. Zone motif wrapped in a cog outline.",
    },
];
---

<BaseLayout
    title="Phosphor — Brand Assets"
    description="Downloadable SVG logos for the Phosphor library suite."
>
    <Topbar crumb="Brand" current="brand" />

    <main id="main" class="container brand-page">

        <PageHero
            title="Brand Assets"
            tagline="Canonical SVG logos, colors, and usage for the Phosphor suite."
        >
            <p class="muted">
                Mirrored from
                <a href="https://github.com/phosphor-works/branding"><code>phosphor-works/branding</code></a>
                and licensed <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC-BY-SA 4.0</a>.
            </p>
        </PageHero>

        <section>
            <h2>Icons</h2>
            <p class="muted">
                Three app icons, each in dark- and light-optimized versions.
                Click any tile to download the raw SVG.
            </p>
            {ICONS.map(icon => (
                <article class="icon-row">
                    <header>
                        <h3>{icon.label}</h3>
                        <p class="muted">{icon.desc}</p>
                    </header>
                    <div class="icon-pair">
                        <a class="icon-tile dark" href={`/brand/assets/dark/${icon.slug}.svg`} download>
                            <img src={`/brand/assets/dark/${icon.slug}.svg`} alt="" loading="lazy" />
                            <div class="icon-meta">
                                <span class="icon-theme">Dark</span>
                                <span class="icon-file">/dark/{icon.slug}.svg</span>
                            </div>
                        </a>
                        <a class="icon-tile light" href={`/brand/assets/light/${icon.slug}.svg`} download>
                            <img src={`/brand/assets/light/${icon.slug}.svg`} alt="" loading="lazy" />
                            <div class="icon-meta">
                                <span class="icon-theme">Light</span>
                                <span class="icon-file">/light/{icon.slug}.svg</span>
                            </div>
                        </a>
                    </div>
                </article>
            ))}
        </section>

        <section>
            <h2>Colors</h2>
            <p class="muted">
                Four gradient stops on a deep-navy surface. The
                <a href="/palette/">palette page</a> has the full Material You
                role map, ANSI 16 terminal mapping, and a live dark/light
                toggle with click-to-copy swatches.
            </p>
            <div class="color-bar" aria-label="Phosphor accent gradient">
                <div><span>Cyan</span><code>#22D3EE</code></div>
                <div><span>Blue</span><code>#3B82F6</code></div>
                <div><span>Purple</span><code>#A855F7</code></div>
                <div><span>Rose</span><code>#F43F5E</code></div>
            </div>
        </section>

        <section>
            <h2>Usage</h2>
            <ul class="links">
                <li>
                    <a href="https://github.com/phosphor-works/branding">Branding repo →</a>
                    <span class="muted">Source SVGs, license, and submodule-consumption instructions.</span>
                </li>
                <li>
                    <a href="/palette/">Brand palette</a>
                    <span class="muted">Full color-role map and terminal-theme bridge.</span>
                </li>
            </ul>
        </section>

        <SiteFooter note="Brand assets · CC-BY-SA 4.0" />

    </main>
</BaseLayout>

<style>
    .brand-page { padding-top: 40px; }

    .icon-row {
        margin-bottom: var(--space-7);
        padding: var(--space-5);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: var(--card);
    }
    .icon-row h3 { margin: 0 0 var(--space-1); font-size: 18px; }
    .icon-row header p { margin: 0 0 var(--space-4); }

    .icon-pair {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3);
    }
    @media (max-width: 640px) {
        .icon-pair { grid-template-columns: 1fr; }
    }

    .icon-tile {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        padding: var(--space-4);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        text-decoration: none;
        color: inherit;
        transition: var(--motion-card);
    }
    .icon-tile:hover {
        transform: translateY(-1px);
        border-color: var(--link);
    }
    /* Brand-asset showcase tiles — these intentionally use brand
       hex literals (not theme tokens) because they're demonstrating
       the canonical palette regardless of which site theme is
       active.  Same hex values surface in src/data/palette.ts. */
    .icon-tile.dark {
        background: var(--accent-gradient);
        color: #F6F9FF;
    }
    .icon-tile.light {
        background:
            linear-gradient(
                90deg,
                rgba(14, 165, 233, var(--opacity-tint)) 0%,
                rgba(59, 130, 246, var(--opacity-tint)) 35%,
                rgba(124, 58, 237, var(--opacity-tint)) 70%,
                rgba(225, 29, 72,  var(--opacity-tint)) 100%
            ),
            #F6F9FF;
        color: var(--brand-void);
    }
    .icon-tile img {
        width: 64px; height: 64px;
        flex-shrink: 0;
    }
    .icon-meta { display: flex; flex-direction: column; min-width: 0; }
    .icon-theme {
        font-size: var(--font-eyebrow);
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: var(--opacity-prose);
    }
    .icon-file {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 12px;
        opacity: var(--opacity-prose);
    }

    .color-bar {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-2);
        margin-top: var(--space-3);
    }
    .color-bar > div {
        padding: var(--space-5) var(--space-4);
        border-radius: var(--radius-md);
        display: flex;
        flex-direction: column;
        gap: 6px;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 12px;
        color: var(--on-primary);
    }
    /* Brand-color showcase: hex values are the canonical palette
       documented in src/data/palette.ts.  See palette.ts BRAND[]
       for the source of truth. */
    .color-bar > div:nth-child(1) { background: var(--brand-cyan); }
    .color-bar > div:nth-child(2) { background: var(--brand-blue);   color: #F6F9FF; }
    .color-bar > div:nth-child(3) { background: var(--brand-purple); color: #F6F9FF; }
    .color-bar > div:nth-child(4) { background: var(--brand-rose);   color: #F6F9FF; }
    /* The <code> hex overrides home.css's generic `code { color:
       var(--brand-cyan) }` so the hex inherits the swatch's own
       color.  On the cyan swatch that's #050916 (dark); on the rest
       it's #F6F9FF.  Without this the hex renders in brand-cyan and
       disappears on the cyan background. */
    .color-bar code {
        color: inherit;
        background: none;
        padding: 0;
        font-size: inherit;
    }
    .color-bar span {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: var(--font-eyebrow);
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: var(--opacity-prose);
    }
    @media (max-width: 640px) {
        .color-bar { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 400px) {
        .color-bar { grid-template-columns: 1fr; }
    }
</style>
