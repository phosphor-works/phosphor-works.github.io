import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { LIBRARIES } from "../../data/libraries";
import "../../styles/home.css";
---

<BaseLayout
    title="Phosphor — Libraries"
    description={`${LIBRARIES.length} focused libraries that make up the Phosphor suite.`}
>
    <Topbar crumb="Libraries" current="libraries" />

    <main id="main" class="container libs-index">

        <PageHero
            title="Libraries"
            tagline={`${LIBRARIES.length} focused libraries. Each does one thing.`}
        >
            <p class="lede">
                Every library is built independently and versioned together.
                Click through for a one-page overview, then follow
                <b>Full API →</b> for the generated type-by-type reference.
            </p>
        </PageHero>

        <ul class="libs-grid card-grid">
            {LIBRARIES.map(lib => (
                <li class="card-surface card-link">
                    <a href={`/libraries/${lib.slug}/`}>
                        <div class="libs-grid-head">
                            <code>{`phosphor-${lib.slug}`}</code>
                            <span class="libs-grid-arrow">→</span>
                        </div>
                        <p>{lib.oneLiner}</p>
                    </a>
                </li>
            ))}
        </ul>

        <SiteFooter note={`${LIBRARIES.length} libraries · GPL-3.0-or-later`} />

    </main>
</BaseLayout>

<style>
    .libs-index { padding-top: 40px; }

    /* .libs-grid composes .card-grid; each <li> composes
       .card-surface + .card-link.  Only the layout inside each tile
       lives here. */
    .libs-grid li a {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 16px 18px;
        text-decoration: none;
        color: inherit;
    }
    .libs-grid-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
    }
    /* Same explicit reset as .libs code on the home page — kills the
       Chromium ghost-underline that otherwise appears under the
       monospace library name. */
    .libs-grid code {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 14px;
        font-weight: 600;
        color: var(--link);
        text-decoration: none;
        background: none;
        padding: 0;
    }
    .libs-grid-arrow { color: var(--fg-muted); font-size: 16px; }
    .libs-grid li:hover .libs-grid-arrow { color: var(--link); }
    .libs-grid li:hover code { color: var(--link-hover); }
    .libs-grid p {
        margin: 0;
        font-size: 13px;
        color: var(--fg-dim);
        line-height: 1.5;
    }
</style>
