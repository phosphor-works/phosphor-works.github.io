import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Card from "../../components/Card.astro";
import CardGrid from "../../components/CardGrid.astro";
import { LIBRARIES } from "../../data/libraries";
import "../../styles/home.css";
---

<BaseLayout
    title="Phosphor — Libraries"
    description={`${LIBRARIES.length} focused libraries that make up the Phosphor suite.`}
>
    <main id="main" class="container libs-index">

        <PageHero
            title="Libraries"
            tagline={`${LIBRARIES.length} focused libraries. Each does one thing.`}
        >
            <p class="lede">
                Every library is built independently and versioned together.
                Click through for a one-page overview, then follow
                <b>Full API →</b> for the generated type-by-type reference.
            </p>
        </PageHero>

        <CardGrid min="280px">
            {LIBRARIES.map(lib => (
                <Card href={`/libraries/${lib.slug}/`} arrow>
                    <code slot="title">phosphor-{lib.slug}</code>
                    <p>{lib.oneLiner}</p>
                </Card>
            ))}
        </CardGrid>

        </main>
</BaseLayout>

<style>
    .libs-index { padding-top: var(--space-8); }
</style>
