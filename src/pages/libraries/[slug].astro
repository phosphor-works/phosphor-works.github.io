---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Per-library landing — dynamic route, one page per entry in
// src/data/libraries.ts.  Shows the one-liner, description, key
// types table, deps list, related-libraries cross-refs, and a
// prominent "Full API →" button into the doxygen reference.

import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import InlineCode from "../../components/InlineCode.astro";
import { LIBRARIES, type Library } from "../../data/libraries";
import "../../styles/home.css";

export function getStaticPaths() {
    return LIBRARIES.map(lib => ({
        params: { slug: lib.slug },
        props: { lib },
    }));
}

interface Props { lib: Library; }
const { lib } = Astro.props;

// Doxygen filename rule: dashes in the lib slug become underscores.
const apiHref = `/api/html/lib_phosphor_${lib.slug.replace(/-/g, "_")}.html`;

const seeAlso = (lib.seeAlso ?? []).map(s => ({
    ...s,
    target: LIBRARIES.find(l => l.slug === s.slug),
})).filter(s => s.target);
---

<BaseLayout
    title={`phosphor-${lib.slug} — Phosphor`}
    description={lib.oneLiner}
>
    <Topbar crumb={`phosphor-${lib.slug}`} current="libraries" />

    <main class="container lib-page">

        <nav class="lib-breadcrumb" aria-label="Breadcrumb">
            <a href="/libraries/">← All libraries</a>
        </nav>

        <PageHero tagline={lib.oneLiner} class="lib-header">
            <code slot="title">phosphor-{lib.slug}</code>
        </PageHero>

        <section class="lib-lede card-surface">
            <p><InlineCode text={lib.description} /></p>
            <a class="lib-cta" href={apiHref}>Full API →</a>
        </section>

        <section>
            <h2>Key types</h2>
            <div class="keytype-grid card-grid">
                {lib.keyTypes.map(t => (
                    <div class="keytype card-surface">
                        <code>{t.name}</code>
                        <span><InlineCode text={t.purpose} /></span>
                    </div>
                ))}
            </div>
        </section>

        <section>
            <h2>Dependencies</h2>
            <ul class="dep-list">
                {lib.deps.map(d => <li><code>{d}</code></li>)}
            </ul>
        </section>

        {seeAlso.length > 0 && (
            <section>
                <h2>See also</h2>
                <ul class="seealso-list">
                    {seeAlso.map(s => (
                        <li class="card-surface">
                            <a href={`/libraries/${s.target!.slug}/`}>
                                <code>phosphor-{s.target!.slug}</code>
                            </a>
                            <span><InlineCode text={s.reason} /></span>
                        </li>
                    ))}
                </ul>
            </section>
        )}

        <section>
            <h2>References</h2>
            <ul class="links">
                <li>
                    <a href={apiHref}>Full API reference →</a>
                    <span class="muted">Doxygen-generated page for <code>{lib.namespace}</code>.</span>
                </li>
                <li>
                    <a href={`/api/html/namespace${lib.namespace}.html`}>Namespace index</a>
                    <span class="muted">Every symbol under <code>{lib.namespace}::</code>.</span>
                </li>
            </ul>
        </section>

        <SiteFooter
            note={`phosphor-${lib.slug} · GPL-3.0-or-later`}
            rightHref="/libraries/"
            rightLabel="All libraries"
        />

    </main>
</BaseLayout>

<style>
    .lib-page { padding-top: 32px; }
    .lib-breadcrumb {
        margin: 0 0 16px;
        font-size: 13px;
    }
    .lib-breadcrumb a {
        color: var(--fg-dim);
        text-decoration: none;
    }
    .lib-breadcrumb a:hover { color: var(--link); }
    /* PageHero renders the h1 at 42px by default; the lib-name h1 is a
       long monospace token so we dial it back to 32px and kill the
       gradient fill so the library identifier reads as an identifier. */
    .lib-header :global(h1) {
        margin: 0 0 6px;
        font-size: 32px;
        background: none;
        -webkit-text-fill-color: var(--link);
        color: var(--link);
    }
    .lib-header :global(h1 code) {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        color: var(--link);
        background: none;
        padding: 0;
        font-size: inherit;
    }

    .lib-lede {
        padding: 24px;
        margin-bottom: 40px;
    }
    .lib-lede p {
        margin: 0 0 18px;
        color: var(--fg);
        line-height: 1.6;
    }
    .lib-cta {
        display: inline-block;
        padding: 10px 18px;
        background: var(--link);
        color: var(--on-primary);
        font-weight: 600;
        border-radius: var(--radius-sm);
        text-decoration: none;
        font-size: 14px;
    }
    .lib-cta:hover { background: var(--link-hover); }

    /* Grid/surface from .card-grid + .card-surface; only the inner
       flex-column + smaller radius + tighter gap live here. */
    .keytype-grid {
        --card-grid-min: 280px;
        gap: 8px;
    }
    .keytype {
        padding: 12px 14px;
        border-radius: var(--radius-sm);
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .keytype code {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 13px;
        font-weight: 600;
        color: var(--link);
        background: none;
        padding: 0;
    }
    .keytype span {
        font-size: 12px;
        color: var(--fg-dim);
    }

    .dep-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .dep-list li {
        padding: 6px 12px;
        border: 1px solid var(--border);
        background: var(--card);
        border-radius: var(--radius-pill);
    }
    .dep-list code {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 12px;
        color: var(--fg);
        background: none;
        padding: 0;
    }

    .seealso-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .seealso-list li {
        padding: 10px 14px;
        border-radius: var(--radius-sm);
    }
    .seealso-list a { margin-right: 6px; }
    .seealso-list span { color: var(--fg-dim); font-size: 13px; }
</style>
