---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Per-library landing — dynamic route, one page per entry in
// src/data/libraries.ts.  Shows the one-liner, description, key
// types table, deps list, related-libraries cross-refs, and a
// prominent "Full API →" button into the doxygen reference.

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import InlineCode from "../../components/InlineCode.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Card from "../../components/Card.astro";
import CardGrid from "../../components/CardGrid.astro";
import Button from "../../components/Button.astro";
import { LIBRARIES, type Library } from "../../data/libraries";
import "../../styles/home.css";

export function getStaticPaths() {
    return LIBRARIES.map(lib => ({
        params: { slug: lib.slug },
        props: { lib },
    }));
}

interface Props { lib: Library; }
const { lib } = Astro.props;

// Doxygen filename rule: dashes in the lib slug become underscores.
const apiHref = `/api/html/lib_phosphor_${lib.slug.replace(/-/g, "_")}.html`;

// Doxygen namespace-page filename rule: `::` mangles to `_1_1`
// (e.g. `Phosphor::Screens` → `namespacePhosphor_1_1Screens.html`).
const namespaceHref = `/api/html/namespace${lib.namespace.replace(/::/g, "_1_1")}.html`;

const seeAlso = (lib.seeAlso ?? []).map(s => ({
    ...s,
    target: LIBRARIES.find(l => l.slug === s.slug),
})).filter(s => s.target);

const ogImage = `/og/library/${lib.slug}.svg`;
const jsonLd = {
    "@type": "SoftwareSourceCode",
    name: `phosphor-${lib.slug}`,
    description: lib.oneLiner,
    codeRepository: "https://github.com/phosphor-works",
    programmingLanguage: "C++",
    url: `https://phosphor-works.github.io/libraries/${lib.slug}/`,
    license: "https://spdx.org/licenses/GPL-3.0-or-later.html",
};
---

<BaseLayout
    title={`phosphor-${lib.slug} — Phosphor`}
    description={lib.oneLiner}
    ogImage={ogImage}
    jsonLd={jsonLd}
>
    <main id="main" class="container lib-page">

        <Breadcrumb href="/libraries/" label="All libraries" />

        <PageHero tagline={lib.oneLiner} class="lib-header">
            <code slot="title">phosphor-{lib.slug}</code>
        </PageHero>

        <section class="lib-lede card-surface">
            <p><InlineCode text={lib.description} /></p>
            <Button href={apiHref} variant="primary">Full API →</Button>
        </section>

        <section>
            <h2>Key types</h2>
            <CardGrid min="280px" gap="var(--space-2)">
                {lib.keyTypes.map(t => (
                    <Card padding="var(--space-3) var(--space-4)">
                        <code slot="title">{t.name}</code>
                        <span><InlineCode text={t.purpose} /></span>
                    </Card>
                ))}
            </CardGrid>
        </section>

        <section>
            <h2>Dependencies</h2>
            <ul class="dep-list">
                {lib.deps.map(d => <li><code>{d}</code></li>)}
            </ul>
        </section>

        {seeAlso.length > 0 && (
            <section>
                <h2>See also</h2>
                <CardGrid as="div" min="100%" gap="var(--space-2)">
                    {seeAlso.map(s => (
                        <Card href={`/libraries/${s.target!.slug}/`} padding="var(--space-3) var(--space-4)">
                            <code slot="title">phosphor-{s.target!.slug}</code>
                            <span><InlineCode text={s.reason} /></span>
                        </Card>
                    ))}
                </CardGrid>
            </section>
        )}

        <section>
            <h2>References</h2>
            <ul class="links">
                <li>
                    <a href={apiHref}>Full API reference →</a>
                    <span class="muted">Doxygen-generated page for <code>{lib.namespace}</code>.</span>
                </li>
                <li>
                    <a href={namespaceHref}>Namespace index</a>
                    <span class="muted">Every symbol under <code>{lib.namespace}::</code>.</span>
                </li>
            </ul>
        </section>

        </main>
</BaseLayout>

<style>
    .lib-page { padding-top: 32px; }
    /* PageHero renders the h1 at 42px by default; the lib-name h1 is a
       long monospace token so we dial it back to 32px and kill the
       gradient fill so the library identifier reads as an identifier. */
    .lib-header :global(h1) {
        margin: 0 0 6px;
        font-size: 32px;
        background: none;
        -webkit-text-fill-color: var(--link);
        color: var(--link);
    }
    .lib-header :global(h1 code) {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        color: var(--link);
        background: none;
        padding: 0;
        font-size: inherit;
    }

    .lib-lede {
        padding: var(--space-6);
        margin-bottom: var(--space-8);
    }
    .lib-lede p {
        margin: 0 0 var(--space-5);
        color: var(--fg);
        line-height: 1.6;
    }

    .dep-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }
    .dep-list li {
        padding: var(--space-1) var(--space-3);
        border: 1px solid var(--border);
        background: var(--card);
        border-radius: var(--radius-pill);
    }
    .dep-list code {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 12px;
        color: var(--fg);
        background: none;
        padding: 0;
    }
</style>
