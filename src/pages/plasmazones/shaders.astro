---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Gallery of built-in GLSL shaders that ship with PlasmaZones.
// Metadata lives in src/data/plasmazones/shaders.json, synced from
// each shader's data/shaders/<id>/metadata.json via
// `npm run sync:plasmazones`.  Video previews are captured
// separately via scripts/capture-shader-previews.sh against a
// running daemon and land in public/plasmazones/shaders/<id>.webm
// + .poster.png.  Shaders without a captured webm fall back to
// the placeholder gradient.

import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import GuideToc from "../../components/GuideToc.astro";
import type { TocEntry } from "../../lib/toc";
import shadersData from "../../data/plasmazones/shaders.json";
import "../../styles/home.css";
import "../../styles/guide.css";

// Detect which shaders have captured preview videos.  import.meta.glob
// resolves at build time — paths that don't exist simply don't show
// up in the returned keys, so we use this to flip each card between
// the video well and the placeholder gradient without hardcoding a
// list.
const videoModules = import.meta.glob("/public/plasmazones/shaders/*.webm", {
    eager: true,
});
const hasVideo = new Set(
    Object.keys(videoModules).map(p =>
        p.replace(/^\/public\/plasmazones\/shaders\//, "")
         .replace(/\.webm$/, "")),
);

interface Shader {
    id: string;
    name: string;
    category: string;
    description: string;
    author: string;
    version?: string;
    multipass?: boolean;
    depthBuffer?: boolean;
    wallpaper?: boolean;
    paramCount: number;
}
const shaders = shadersData as Shader[];

// Ordered groups with short blurbs.  Categories come straight from
// the shader metadata — the settings picker groups by the same key.
const GROUPS: { cat: string; blurb: string }[] = [
    {
        cat: "Branded",
        blurb: "Distro-themed. Logos, palettes, and visual motifs for specific Linux distributions.",
    },
    {
        cat: "Audio Visualizer",
        blurb: "Reactive to CAVA — bass, mids, treble, or the full spectrum. Enable audio visualization in Settings.",
    },
    {
        cat: "Cyberpunk",
        blurb: "Neon, grids, CRT artifacts, and scan lines. Heavy on saturated rose, cyan, and purple.",
    },
    {
        cat: "Energy",
        blurb: "Plasma-like motion — pulses, arcs, and charge fields that don't tie to a color scheme.",
    },
    {
        cat: "Organic",
        blurb: "Soft edges, flow, and drift. Slower cadence that reads as ambient rather than reactive.",
    },
    {
        cat: "3D",
        blurb: "Multipass effects with a depth buffer. Camera-stable scenes that feel like a window into a bigger world.",
    },
];

const grouped = GROUPS.map(g => ({
    ...g,
    items: shaders.filter(s => s.category === g.cat),
})).filter(g => g.items.length > 0);

// Shaders with a category outside the known set still render —
// surface them at the end so nothing goes missing.
const known = new Set(GROUPS.map(g => g.cat));
const extras = shaders.filter(s => !known.has(s.category));

const slugify = (s: string) => s.toLowerCase().replace(/\s+/g, "-");

// Build the TOC from the rendered groups directly — dynamic h2 ids
// from JSX expressions can't be picked up by the regex-based
// extractGuideHeadings(), and the conditional "Other" section
// should only show in the TOC when there are uncategorized shaders
// to put in it.
const toc: TocEntry[] = [
    ...grouped.map(g => ({ level: 2 as const, href: `#${slugify(g.cat)}`, label: g.cat })),
    ...(extras.length > 0 ? [{ level: 2 as const, href: "#other", label: "Other" }] : []),
    { level: 2, href: "#next", label: "Using shaders" },
];

function tagsFor(shader: Shader): string[] {
    const tags: string[] = [];
    if (shader.multipass) tags.push("multipass");
    if (shader.depthBuffer) tags.push("depth");
    if (shader.wallpaper) tags.push("wallpaper");
    if (shader.category === "Audio Visualizer") tags.push("audio-reactive");
    return tags;
}
---

<BaseLayout
    title="Shader gallery — PlasmaZones"
    description="Every GLSL shader that ships with PlasmaZones: branded, audio-reactive, cyberpunk, energy, organic, and 3D categories."
>
    <Topbar crumb="Shaders" current="plasmazones" />

    <main id="main" class="container guide">

        <Breadcrumb href="/plasmazones/" label="PlasmaZones" />

        <PageHero
            title="Shader gallery"
            tagline="Every shader that ships with PlasmaZones, with category, author, and tunable-parameter count."
        >
            <p class="muted">
                Shaders render through a multipass GLSL
                <code>ShaderEffect</code> as zone highlights, snap
                previews, and drag ghosts. 26 effects ship in-box
                across six categories; user shaders drop into
                <code>~/.local/share/plasmazones/shaders/</code> and
                hot-reload on save. Authoring contract, uniform
                block, and helper functions are in the
                <a href="/guides/shaders/">Shader authoring guide</a>.
            </p>
        </PageHero>

        <GuideToc entries={toc} />

        {grouped.map(group => (
            <Fragment>
                <h2 id={slugify(group.cat)}>{group.cat}</h2>
                <p class="muted">{group.blurb}</p>
                <ul class="shader-grid card-grid" style="--card-grid-min: 320px">
                    {group.items.map(shader => (
                        <li class="card-surface shader-card">
                            {hasVideo.has(shader.id) ? (
                                <video
                                    class="shader-thumb shader-thumb-video"
                                    src={`/plasmazones/shaders/${shader.id}.webm`}
                                    poster={`/plasmazones/shaders/${shader.id}.poster.png`}
                                    preload="none"
                                    muted
                                    loop
                                    playsinline
                                    disablepictureinpicture
                                    aria-label={`${shader.name} preview`}
                                    onmouseenter="this.play()"
                                    onmouseleave="this.pause(); this.currentTime = 0;"
                                />
                            ) : (
                                <div class="shader-thumb">
                                    <span class="shader-thumb-id">{shader.id}</span>
                                    <span class="shader-thumb-note">preview pending</span>
                                </div>
                            )}
                            <div class="shader-meta">
                                <strong>{shader.name}</strong>
                                <span class="muted shader-desc">{shader.description}</span>
                                <div class="shader-tags">
                                    {tagsFor(shader).map(tag => (
                                        <span class="shader-tag">{tag}</span>
                                    ))}
                                    <span class="shader-tag shader-tag-params">
                                        {shader.paramCount} param{shader.paramCount === 1 ? "" : "s"}
                                    </span>
                                </div>
                                <span class="shader-author">{shader.author}</span>
                            </div>
                        </li>
                    ))}
                </ul>
            </Fragment>
        ))}

        {extras.length > 0 && (
            <Fragment>
                <h2 id="other">Other</h2>
                <p class="muted">Custom categories registered by shaders outside the built-in set.</p>
                <ul class="shader-grid card-grid" style="--card-grid-min: 320px">
                    {extras.map(shader => (
                        <li class="card-surface shader-card">
                            {hasVideo.has(shader.id) ? (
                                <video
                                    class="shader-thumb shader-thumb-video"
                                    src={`/plasmazones/shaders/${shader.id}.webm`}
                                    poster={`/plasmazones/shaders/${shader.id}.poster.png`}
                                    preload="none"
                                    muted
                                    loop
                                    playsinline
                                    disablepictureinpicture
                                    aria-label={`${shader.name} preview`}
                                    onmouseenter="this.play()"
                                    onmouseleave="this.pause(); this.currentTime = 0;"
                                />
                            ) : (
                                <div class="shader-thumb">
                                    <span class="shader-thumb-id">{shader.id}</span>
                                    <span class="shader-thumb-note">preview pending</span>
                                </div>
                            )}
                            <div class="shader-meta">
                                <strong>{shader.name}</strong>
                                <span class="muted shader-desc">{shader.description}</span>
                                <span class="shader-author">{shader.author} · {shader.category}</span>
                            </div>
                        </li>
                    ))}
                </ul>
            </Fragment>
        )}

        <h2 id="next">Using shaders</h2>
        <ul class="links">
            <li>
                <a href="/guides/shaders/">Shader authoring guide →</a>
                <span class="muted">GLSL 450 contract, uniform block, metadata schema, multipass, audio reactivity.</span>
            </li>
            <li>
                <a href="/plasmazones/dbus/#interfaces">Shader D-Bus interface →</a>
                <span class="muted">Enumerate, refresh, and open the user-shader directory from scripts.</span>
            </li>
            <li>
                <a href="https://github.com/fuddlesworth/PlasmaZones/tree/main/data/shaders">Bundled shader sources on GitHub →</a>
                <span class="muted">Every shader listed here, complete with GLSL source for reference.</span>
            </li>
        </ul>

        <SiteFooter rightHref="/plasmazones/" rightLabel="Back to PlasmaZones" />

    </main>
</BaseLayout>

<style>
    .shader-grid { padding: 0; list-style: none; margin: 0 0 24px; }
    .shader-card {
        display: flex;
        flex-direction: column;
        gap: 0;
        overflow: hidden;
    }
    .shader-thumb {
        aspect-ratio: 16 / 9;
        background: var(--code-bg);
        border-bottom: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        color: var(--fg-muted);
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        position: relative;
        overflow: hidden;
    }
    /* Video variant: same aspect-ratio well, but the <video> fills
       it end-to-end (no letterboxing) and the hover play/pause is
       inline-handler-driven so the card stays crisp on a cold
       network. */
    .shader-thumb-video {
        width: 100%;
        height: auto;
        display: block;
        object-fit: cover;
    }
    .shader-thumb::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 20% 30%, rgba(34,211,238,0.08), transparent 50%),
            radial-gradient(circle at 80% 70%, rgba(168,85,247,0.08), transparent 55%),
            radial-gradient(circle at 50% 50%, rgba(251,113,133,0.05), transparent 60%);
        pointer-events: none;
    }
    .shader-thumb-id {
        position: relative;
        font-size: 13px;
        color: var(--fg-dim);
    }
    .shader-thumb-note {
        position: relative;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--fg-muted);
        opacity: 0.7;
    }
    .shader-meta {
        padding: 12px 14px 14px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .shader-meta strong {
        color: var(--fg);
        font-size: 14.5px;
        font-weight: 600;
    }
    .shader-desc {
        font-size: 12.5px;
        line-height: 1.55;
    }
    .shader-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-top: 2px;
    }
    .shader-tag {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: var(--link);
        background: var(--card-high);
        border: 1px solid var(--border);
        border-radius: var(--radius-xs);
        padding: 2px 6px;
    }
    .shader-tag-params {
        color: var(--fg-muted);
    }
    .shader-author {
        font-size: 11px;
        color: var(--fg-muted);
        margin-top: 2px;
    }
</style>
