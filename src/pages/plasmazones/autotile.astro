---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Gallery of built-in autotile algorithms that ship with
// PlasmaZones.  Metadata lives in src/data/plasmazones/
// algorithms.json, parsed from each data/algorithms/<id>.js file's
// top-level `var metadata = { ... }` object via
// `npm run sync:plasmazones`.  Family groupings are authored here
// since the source files don't tag a family.

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import GuideToc from "../../components/GuideToc.astro";
import AlgoCard from "../../components/AlgoCard.astro";
import { extractGuideHeadings } from "../../lib/toc";
import algorithmsData from "../../data/plasmazones/algorithms.json";
import "../../styles/home.css";
import "../../styles/guide.css";

interface Algorithm {
    id: string;
    name: string;
    description: string;
    producesOverlappingZones?: boolean;
    supportsMasterCount?: boolean;
    supportsSplitRatio?: boolean;
    supportsMemory?: boolean;
    centerLayout?: boolean;
    defaultMaxWindows?: number;
    defaultSplitRatio?: number;
    minimumWindows?: number;
    preview?: { x: number; y: number; width: number; height: number }[];
}
const algos = algorithmsData as Algorithm[];
const byId = Object.fromEntries(algos.map(a => [a.id, a]));

// Per-family algorithm ID lists.  Headings, blurbs, and ordering are
// inlined as literal markup below so the standard TOC extractor sees
// every section — same pattern as every other guide page.
const MASTER_STACK = ["master-stack", "centered-master", "corner-master", "focus-sidebar", "quadrant-priority", "three-column", "wide"];
const TREE         = ["bsp", "dwindle", "dwindle-memory", "spiral"];
const GRID         = ["columns", "rows", "grid", "cluster", "tatami"];
const STACKING     = ["cascade", "deck", "horizontal-deck", "monocle", "paper", "spread", "stair"];
const OTHER        = ["floating-center", "zen"];

const covered = new Set([...MASTER_STACK, ...TREE, ...GRID, ...STACKING, ...OTHER]);
const uncategorized = algos.filter(a => !covered.has(a.id));

const pick = (ids: string[]) => ids.map(id => byId[id]).filter(Boolean);

const toc = extractGuideHeadings(import.meta.url)
    .filter(e => e.href !== "#uncategorized" || uncategorized.length > 0);
---

<BaseLayout
    title="Autotile algorithms — PlasmaZones"
    description="Every built-in JavaScript autotile algorithm that ships with PlasmaZones, grouped by family with supported parameters."
>
    <main id="main" class="container guide with-toc">

        <article class="guide-content">

        <Breadcrumb />

        <PageHero
            title="Autotile algorithms"
            tagline="Every autotile algorithm that ships with PlasmaZones. Built-ins below; drop your own JS alongside them."
        >
            <p class="lede">
                Algorithms run in a sandboxed QJSEngine and receive a
                <code>params</code> object each layout request. 25
                ship in-box across four main families. Custom
                algorithms drop into
                <code>~/.local/share/plasmazones/algorithms/</code>
                and hot-reload on save. The
                <a href="/guides/tiling/">Tiling authoring guide</a>
                covers the contract, metadata fields, and built-in
                helpers.
            </p>
        </PageHero>

        <h2 id="master-stack">Master and stack</h2>
        <p class="muted">One or more master windows with secondary windows in a stack alongside. Configurable master count and split ratio.</p>
        <ul class="algo-grid card-grid" style="--card-grid-min: 300px">
            {pick(MASTER_STACK).map(algo => <AlgoCard algo={algo} />)}
        </ul>

        <h2 id="tree">Recursive and tree</h2>
        <p class="muted">Each new window splits an existing region. Deterministic geometry from window arrival order (unless marked with memory).</p>
        <ul class="algo-grid card-grid" style="--card-grid-min: 300px">
            {pick(TREE).map(algo => <AlgoCard algo={algo} />)}
        </ul>

        <h2 id="grid">Grid and even division</h2>
        <p class="muted">All windows treated equally. Cells sized to fill the available area with no master.</p>
        <ul class="algo-grid card-grid" style="--card-grid-min: 300px">
            {pick(GRID).map(algo => <AlgoCard algo={algo} />)}
        </ul>

        <h2 id="stacking">Stacking and overlapping</h2>
        <p class="muted">Windows can share screen space. Either a single-visible stack (Monocle), a cascade offset, or a rolling deck.</p>
        <ul class="algo-grid card-grid" style="--card-grid-min: 300px">
            {pick(STACKING).map(algo => <AlgoCard algo={algo} />)}
        </ul>

        <h2 id="other">Other</h2>
        <p class="muted">Layouts that don't fit the above families.</p>
        <ul class="algo-grid card-grid" style="--card-grid-min: 300px">
            {pick(OTHER).map(algo => <AlgoCard algo={algo} />)}
        </ul>

        {uncategorized.length > 0 && (
            <Fragment>
                <h2 id="uncategorized">Uncategorized</h2>
                <p class="muted">Algorithms not yet assigned to a family; likely new additions.</p>
                <ul class="algo-grid card-grid" style="--card-grid-min: 300px">
                    {uncategorized.map(algo => <AlgoCard algo={algo} />)}
                </ul>
            </Fragment>
        )}

        <h2 id="tags">Tag reference</h2>
        <ul>
            <li>
                <b>master count</b> — the algorithm reads
                <code>params.masterCount</code>. Settings exposes a
                per-screen master-count slider when this is set.
            </li>
            <li>
                <b>split ratio</b> — the algorithm reads
                <code>params.splitRatio</code>. Settings exposes a
                ratio slider bounded by the algorithm's
                <code>PZ_MIN_SPLIT</code> / <code>PZ_MAX_SPLIT</code>
                constants.
            </li>
            <li>
                <b>stateful</b> — keeps a binary tree across layout
                requests in <code>params.tree</code>. Window
                positions stay stable when new windows are added to
                an existing tree.
            </li>
            <li>
                <b>overlapping</b> — zones can overlap (stacking and
                deck layouts). The overlay renders z-ordered zones
                from back to front.
            </li>
            <li>
                <b>centered</b> — the algorithm centers its output
                in the tileable area. Leaves margins rather than
                expanding to fill.
            </li>
        </ul>

        <h2 id="next">Using autotile</h2>
        <ul class="links">
            <li>
                <a href="/guides/tiling/">Tiling authoring guide →</a>
                <span class="muted">Write your own. Sandbox contract, metadata fields, built-in helpers, and hot-reload setup.</span>
            </li>
            <li>
                <a href="/plasmazones/shortcuts/#autotile">Autotile shortcuts →</a>
                <span class="muted">Toggle autotile, change the master ratio/count, retile, and swap with master.</span>
            </li>
            <li>
                <a href="/plasmazones/dbus/#recipe-autotile">Autotile over D-Bus →</a>
                <span class="muted">Toggle per screen, force retile, or change algorithm from a script.</span>
            </li>
            <li>
                <a href="https://github.com/fuddlesworth/PlasmaZones/tree/main/data/algorithms">Bundled algorithm sources on GitHub →</a>
                <span class="muted">Every algorithm listed here, with the full JS source for reference.</span>
            </li>
        </ul>

        </article>

        <GuideToc entries={toc} />

        </main>
</BaseLayout>

<style>
    .algo-grid { padding: 0; list-style: none; margin: 0 0 24px; }
</style>
