// Migration page for FancyZones users.  Feature map + differences
// sourced from the PlasmaZones repo (README, configdefaults.h,
// data/layouts/, CMakeLists).

import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import "../../styles/home.css";
import "../../styles/guide.css";

interface FeatureRow {
    fancyzones: string;
    plasmazones: string;
    note?: string;
}

const FEATURE_MAP: FeatureRow[] = [
    {
        fancyzones: "Hold Shift while dragging to show zones",
        plasmazones: "Hold Alt while dragging (configurable to Meta / Ctrl+Alt / Alt+Shift / Alt+Meta / Ctrl+Alt+Meta)",
    },
    {
        fancyzones: "Grid, Columns, Rows, Priority Grid layout presets",
        plasmazones: "27 built-in presets",
        note: "Grid, Columns 2/3, Rows 2, Master+Stack, BSP / Fibonacci, Priority Grid, Portrait (5 variants), Superwide (4), Ultrawide (5), Wide, Focus, Split-focus.  Plus custom zones drawn freehand.",
    },
    {
        fancyzones: "Quick-swap layouts via number keys",
        plasmazones: "Quick-layout slots bound to Meta+Alt+1 … Meta+Alt+9",
    },
    {
        fancyzones: "Per-monitor layouts",
        plasmazones: "Per-monitor + per-virtual-screen layouts",
        note: "PlasmaZones adds a virtual-screen axis (subdivide any monitor into 2–10 logical workspaces, each with its own layout + autotile state + settings).",
    },
    {
        fancyzones: "Span zones across monitors (hold modifier while dragging)",
        plasmazones: "Zone span across adjacent zones on the same screen",
        note: "Default span modifier is Ctrl+Alt.  Cross-physical-monitor span isn't supported; use a virtual-screen layout on the single monitor instead.",
    },
    {
        fancyzones: "Custom zone colors + opacity",
        plasmazones: "23 GLSL shader effects (audio-reactive included), or write your own",
        note: "Effects live in ~/.local/share/plasmazones/shaders/ and hot-reload.  See /guides/shaders/.",
    },
    {
        fancyzones: "App exclusion list (by window class)",
        plasmazones: "App exclusion by window class + minimum-size threshold + per-app floating toggle",
    },
    {
        fancyzones: "(not in FancyZones)",
        plasmazones: "App-to-zone rules — auto-snap specific apps to specific zones on launch",
    },
    {
        fancyzones: "Settings UI via PowerToys",
        plasmazones: "System Settings › Application Management › PlasmaZones (or standalone plasmazones-settings)",
    },
    {
        fancyzones: "(not in FancyZones)",
        plasmazones: "Autotile with 24 pluggable JS algorithms (Master+Stack, BSP, Spiral, Grid, Monocle, …)",
        note: "Off by default.  Toggle per-screen with Meta+Shift+T.  Custom algorithms drop into ~/.local/share/plasmazones/algorithms/ and hot-reload.",
    },
    {
        fancyzones: "(not in FancyZones)",
        plasmazones: "Snap Assist — after snapping, empty zones show thumbnails of other windows for one-click next-snap",
    },
];
---

<BaseLayout
    title="From FancyZones — PlasmaZones"
    description="PlasmaZones for users coming from Windows FancyZones: feature map, keyboard equivalents, and what's different."
>
    <Topbar crumb="From FancyZones" current="plasmazones" />

    <main id="main" class="container guide">

        <nav class="lib-breadcrumb" aria-label="Breadcrumb">
            <a href="/plasmazones/">← PlasmaZones</a>
        </nav>

        <PageHero
            title="Coming from FancyZones"
            tagline="Feature-by-feature map for the PowerToys → Plasma jump."
        >
            <p class="muted">
                PlasmaZones was started to fill the FancyZones gap
                after a Windows → KDE Plasma move.  This page walks a
                FancyZones user through what maps directly, what's
                different, and what isn't supported.
            </p>
        </PageHero>

        <section>
            <h2>Feature map</h2>
            <table>
                <thead>
                    <tr>
                        <th>FancyZones</th>
                        <th>PlasmaZones</th>
                    </tr>
                </thead>
                <tbody>
                    {FEATURE_MAP.map(r => (
                        <tr>
                            <td>{r.fancyzones}</td>
                            <td>
                                {r.plasmazones}
                                {r.note && <><br/><span class="muted">{r.note}</span></>}
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </section>

        <section>
            <h2>What's different</h2>
            <ul>
                <li>
                    <b>Shader-driven highlights.</b> FancyZones uses
                    solid fills with opacity.  PlasmaZones runs every
                    overlay (snap preview, zone highlight, drag ghost)
                    through a multipass GLSL ShaderEffect.  The
                    default preset reads like a clean FancyZones fill;
                    swap to any of the 23 bundled effects (including
                    audio-reactive) or write your own.
                </li>
                <li>
                    <b>Scriptable tiling.</b> FancyZones is
                    layout-only.  PlasmaZones optionally autotiles
                    new windows via 24 built-in JavaScript
                    algorithms, with hot-reload for custom ones.
                    Off by default.
                </li>
                <li>
                    <b>Virtual screens.</b> Split any physical
                    monitor into up to 10 logical workspaces, each
                    with its own layout, autotile state, and
                    settings.  Windows has no equivalent axis.
                </li>
                <li>
                    <b>Three-file config split.</b> Settings
                    (<code>config.json</code>), per-screen layout
                    assignments (<code>assignments.json</code>), and
                    ephemeral state (<code>session.json</code>)
                    live separately under
                    <code>~/.config/plasmazones/</code> to avoid
                    write contention.
                </li>
                <li>
                    <b>Wayland-native.</b> No X11 fallback path.
                    X11 support was removed in v1.2.0 — Plasma 6 is
                    Wayland-first, and the layer-shell overlay
                    requires it.  XWayland apps still snap; drag-
                    insert into an autotile layout has minor limits
                    because XWayland emulates input reporting.
                </li>
            </ul>
        </section>

        <section>
            <h2>Not supported</h2>
            <ul>
                <li>Cross-physical-monitor zone span.  Use a virtual-screen layout on a single monitor instead.</li>
                <li>X11 session — PlasmaZones is Wayland-only as of v1.2.0.</li>
                <li>Per-app "disable snapping for this process" rule.  Global class-based exclusion lists cover most of the same need.</li>
            </ul>
        </section>

        <section>
            <h2>Picking up where you left off</h2>
            <ul class="links">
                <li>
                    <a href="/plasmazones/#install">Install →</a>
                    <span class="muted">Distro packages + source build.</span>
                </li>
                <li>
                    <a href="/plasmazones/getting-started/">First-run tour →</a>
                    <span class="muted">From install to your first snap.</span>
                </li>
                <li>
                    <a href="/plasmazones/shortcuts/">Shortcut reference →</a>
                    <span class="muted">Every default binding.</span>
                </li>
            </ul>
        </section>

        <SiteFooter rightHref="/plasmazones/" rightLabel="Back to PlasmaZones" />

    </main>
</BaseLayout>

<style>
    .lib-breadcrumb { margin: 0 0 16px; font-size: 13px; }
    .lib-breadcrumb a { color: var(--fg-dim); text-decoration: none; }
    .lib-breadcrumb a:hover { color: var(--link); }
</style>
