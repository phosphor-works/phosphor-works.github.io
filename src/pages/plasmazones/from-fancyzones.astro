---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Migration page for FancyZones users.  Feature map + differences
// sourced from the PlasmaZones repo.

import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import GuideToc from "../../components/GuideToc.astro";
import { extractGuideHeadings } from "../../lib/toc";
import "../../styles/home.css";
import "../../styles/guide.css";

const toc = extractGuideHeadings(import.meta.url);

interface FeatureRow {
    fancyzones: string;
    plasmazones: string;
    note?: string;
}

const FEATURE_MAP: FeatureRow[] = [
    {
        fancyzones: "Hold Shift while dragging to show zones",
        plasmazones: "Hold Alt while dragging",
        note: "Drag modifier configurable to Meta, Ctrl+Alt, Alt+Shift, Alt+Meta, or Ctrl+Alt+Meta.",
    },
    {
        fancyzones: "Grid, Columns, Rows, Priority Grid layout presets",
        plasmazones: "27 built-in presets + custom zones drawn freehand",
        note: "Grid, Columns 2/3, Rows 2, Master+Stack, BSP / Fibonacci, Priority Grid, Portrait (5 variants), Superwide (4), Ultrawide (5), Wide, Focus, Split-focus.",
    },
    {
        fancyzones: "Quick-swap layouts via number keys",
        plasmazones: "Quick-layout slots bound to Meta+Alt+1 … Meta+Alt+9",
    },
    {
        fancyzones: "Per-monitor layouts",
        plasmazones: "Per-monitor and per-virtual-screen layouts",
        note: "You can subdivide a monitor into 2–10 virtual screens, each with its own layout, autotile state, and settings.",
    },
    {
        fancyzones: "Span zones across monitors",
        plasmazones: "Zone span across adjacent zones on the same screen",
        note: "The default span modifier is Ctrl+Alt. Crossing a physical-monitor boundary isn't supported, so subdivide the monitor into virtual screens if you need it.",
    },
    {
        fancyzones: "Custom zone colors + opacity",
        plasmazones: "Same per-zone colors and opacity, plus optional GLSL shader effects",
        note: "highlightColor, activeOpacity, and inactiveOpacity are per-zone controls just like FancyZones. For more, the overlay runs through a multipass ShaderEffect with 23 bundled presets, or your own GLSL in ~/.local/share/plasmazones/shaders/.",
    },
    {
        fancyzones: "App exclusion list by window class",
        plasmazones: "App exclusion by window class, plus minimum-size threshold and per-app floating toggle",
    },
    {
        fancyzones: "App Layouts: assign specific apps to specific zones",
        plasmazones: "App-to-zone rules with the same capability under a different name",
        note: "Configured under Settings › App Rules, and matching windows snap on open.",
    },
    {
        fancyzones: "Auto-apply layout to newly-created windows",
        plasmazones: "Auto-apply, plus 24 JavaScript autotile algorithms",
        note: "Ships with BSP, Spiral, Master+Stack, Grid, and Monocle among others, and hot-reloads custom ones from ~/.local/share/plasmazones/algorithms/.",
    },
    {
        fancyzones: "Settings UI via PowerToys",
        plasmazones: "System Settings › Application Management › PlasmaZones",
        note: "Or open the standalone plasmazones-settings launcher.",
    },
    {
        fancyzones: "No equivalent; Windows' own Snap Assist is a separate OS feature",
        plasmazones: "Post-snap zone thumbnails",
        note: "After you drop a window into a zone, empty zones show thumbnails of other windows for a one-click follow-up snap.",
    },
];

const DIFFERENCES = [
    {
        title: "Optional shader layer",
        body: "Per-zone colors and opacity work the same as FancyZones. The overlay also runs through a multipass GLSL ShaderEffect, with 23 bundled presets including audio-reactive ones and room for custom shaders.",
    },
    {
        title: "Scriptable autotile",
        body: "FancyZones auto-applies a layout to new windows. PlasmaZones does the same and adds 24 JavaScript algorithms like BSP, Spiral, Master+Stack, Grid, and Monocle, with hot-reload for custom ones. Off by default.",
    },
    {
        title: "Virtual screens",
        body: "Split any physical monitor into up to 10 logical workspaces, each with its own layout, autotile state, and settings. Windows has no equivalent axis.",
    },
    {
        title: "Three-file config split",
        body: "Three files live under ~/.config/plasmazones/: config.json for settings, assignments.json for per-screen layouts, and session.json for ephemeral state. Splitting them avoids write contention.",
    },
    {
        title: "Wayland-only",
        body: "X11 support was removed in v1.2.0; the layer-shell overlay requires Wayland. XWayland apps still snap, but autotile's drag-insert is flakier there since XWayland emulates input reporting.",
    },
];

const UNSUPPORTED = [
    "Cross-physical-monitor zone span; use a virtual-screen layout on a single monitor instead.",
    "X11 session; PlasmaZones is Wayland-only as of v1.2.0.",
    "Per-app \"disable snapping for this process\" rule, though global class-based exclusion lists cover most of the same need.",
];
---

<BaseLayout
    title="From FancyZones — PlasmaZones"
    description="PlasmaZones for users coming from Windows FancyZones: feature map, keyboard equivalents, and what's different."
>
    <Topbar crumb="From FancyZones" current="plasmazones" />

    <main id="main" class="container guide">

        <Breadcrumb href="/plasmazones/" label="PlasmaZones" />

        <PageHero
            title="Coming from FancyZones"
            tagline="Feature map and keyboard equivalents for the FancyZones-to-Plasma jump."
        >
            <p class="muted">
                PlasmaZones was started to scratch the FancyZones
                itch after moving from Windows to KDE Plasma. If
                you already know FancyZones, most of it transfers.
            </p>
        </PageHero>

        <GuideToc entries={toc} />

        <h2 id="feature-map">Feature map</h2>
        <ul class="compare-list">
            {FEATURE_MAP.map(r => (
                <li class="card-surface">
                    <div class="compare-side compare-before">
                        <span class="compare-label">FancyZones</span>
                        <span class="compare-body">{r.fancyzones}</span>
                    </div>
                    <div class="compare-side compare-after">
                        <span class="compare-label">PlasmaZones</span>
                        <span class="compare-body">
                            {r.plasmazones}
                            {r.note && <span class="compare-note">{r.note}</span>}
                        </span>
                    </div>
                </li>
            ))}
        </ul>

        <h2 id="differences">What's different</h2>
        <ul class="diff-grid card-grid" style="--card-grid-min: 320px">
            {DIFFERENCES.map(d => (
                <li class="card-surface">
                    <strong class="diff-title">{d.title}</strong>
                    <span class="diff-body">{d.body}</span>
                </li>
            ))}
        </ul>

        <h2 id="unsupported">Not supported</h2>
        <ul class="links">
            {UNSUPPORTED.map(u => <li><span class="muted">{u}</span></li>)}
        </ul>

        <h2 id="next">Next</h2>
        <ul class="links">
            <li>
                <a href="/plasmazones/#install">Install →</a>
                <span class="muted">Distro packages and source build.</span>
            </li>
            <li>
                <a href="/plasmazones/getting-started/">First-run tour →</a>
                <span class="muted">Verify the install, open the editor, snap a window.</span>
            </li>
            <li>
                <a href="/plasmazones/shortcuts/">Shortcut reference →</a>
                <span class="muted">Every default binding.</span>
            </li>
        </ul>

        <SiteFooter rightHref="/plasmazones/" rightLabel="Back to PlasmaZones" />

    </main>
</BaseLayout>

<style>
    .diff-grid li {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 14px 16px;
    }
    .diff-title {
        font-size: 14.5px;
        font-weight: 600;
        color: var(--fg);
    }
    .diff-body {
        font-size: 14px;
        color: var(--fg-dim);
        line-height: 1.6;
    }
</style>
