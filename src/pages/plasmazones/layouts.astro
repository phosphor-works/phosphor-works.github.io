---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Gallery of built-in layouts that ship with PlasmaZones.  Metadata
// lives in src/data/plasmazones/layouts.json, synced from the
// PlasmaZones repo via `npm run sync:plasmazones`.  Each layout's
// zones have relativeGeometry {x, y, width, height} in [0,1], which
// LayoutCard renders as SVG rects inside an aspect-ratio-matched
// viewBox.

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import GuideToc from "../../components/GuideToc.astro";
import LayoutCard from "../../components/LayoutCard.astro";
import { extractGuideHeadings } from "../../lib/toc";
import layoutsData from "../../data/plasmazones/layouts.json";
import "../../styles/home.css";
import "../../styles/guide.css";

interface Zone {
    id: string;
    name: string;
    zoneNumber: number;
    relativeGeometry: { x: number; y: number; width: number; height: number };
}
interface Layout {
    id: string;
    name: string;
    description: string;
    aspectRatioClass: string;
    defaultOrder?: number;
    zones: Zone[];
}

const layouts = layoutsData as Layout[];
const byClass = (cls: string) => layouts.filter(l => l.aspectRatioClass === cls);

const standard       = byClass("standard");
const portrait       = byClass("portrait");
const ultrawide      = byClass("ultrawide");
const superUltrawide = byClass("super-ultrawide");

// Drop empty-section TOC entries — the standard regex extractor
// finds every literal <h2> in the source, including ones whose JSX
// guard evaluates to false at build time.
const present = new Set<string>();
if (standard.length)       present.add("#standard");
if (portrait.length)       present.add("#portrait");
if (ultrawide.length)      present.add("#ultrawide");
if (superUltrawide.length) present.add("#super-ultrawide");

const toc = extractGuideHeadings(import.meta.url)
    .filter(e => !["#standard", "#portrait", "#ultrawide", "#super-ultrawide"].includes(e.href) || present.has(e.href));
---

<BaseLayout
    title="Layout gallery — PlasmaZones"
    description="Every layout that ships with PlasmaZones: standard, portrait, ultrawide, and superwide variants with live-rendered previews."
>
    <main id="main" class="container guide with-toc">

        <article class="guide-content">

        <Breadcrumb />

        <PageHero
            title="Layout gallery"
            tagline="Every layout that ships with PlasmaZones, rendered from the same JSON the daemon loads at runtime."
        >
            <p class="lede">
                Layouts use normalized 0–1 coordinates, so the same
                JSON works at any screen size. Each thumbnail below
                is a direct SVG render of the layout's zones at the
                aspect ratio the class is designed for. Build your
                own in the editor (<code>Meta+Shift+E</code>) — see
                the <a href="/plasmazones/getting-started/">first-run
                tour</a> for the walkthrough.
            </p>
        </PageHero>

        {standard.length > 0 && (
            <Fragment>
                <h2 id="standard">Standard (16:9 / 16:10)</h2>
                <p class="muted">Desktop and laptop monitors. The default set for most users.</p>
                <ul class="layout-grid card-grid" style="--card-grid-min: 240px">
                    {standard.map(layout => <LayoutCard layout={layout} />)}
                </ul>
            </Fragment>
        )}

        {portrait.length > 0 && (
            <Fragment>
                <h2 id="portrait">Portrait (9:16)</h2>
                <p class="muted">Rotated monitors. Document-first layouts with rows stacked vertically.</p>
                <ul class="layout-grid card-grid" style="--card-grid-min: 240px">
                    {portrait.map(layout => <LayoutCard layout={layout} />)}
                </ul>
            </Fragment>
        )}

        {ultrawide.length > 0 && (
            <Fragment>
                <h2 id="ultrawide">Ultrawide (21:9)</h2>
                <p class="muted">Single-monitor 3–4 column splits with optional center-focus variants.</p>
                <ul class="layout-grid card-grid" style="--card-grid-min: 240px">
                    {ultrawide.map(layout => <LayoutCard layout={layout} />)}
                </ul>
            </Fragment>
        )}

        {superUltrawide.length > 0 && (
            <Fragment>
                <h2 id="super-ultrawide">Super-ultrawide (32:9 and 49")</h2>
                <p class="muted">Samsung Odyssey G9 / Neo G9 class. Six-tile and dual / triple arrangements.</p>
                <ul class="layout-grid card-grid" style="--card-grid-min: 240px">
                    {superUltrawide.map(layout => <LayoutCard layout={layout} />)}
                </ul>
            </Fragment>
        )}

        <h2 id="next">Using layouts</h2>
        <ul class="links">
            <li>
                <a href="/plasmazones/getting-started/#editor">Open the zone editor →</a>
                <span class="muted">Pick a preset, tweak the gutters, or draw custom zones freehand.</span>
            </li>
            <li>
                <a href="/plasmazones/shortcuts/#layouts">Layout switching shortcuts →</a>
                <span class="muted">Previous / next / quick-layout slots bound to Meta+Alt+1..9.</span>
            </li>
            <li>
                <a href="/plasmazones/dbus/#recipe-layouts">Switch layouts over D-Bus →</a>
                <span class="muted">Set the active layout, apply a quick-layout slot, or list everything from a script.</span>
            </li>
        </ul>

        </article>

        <GuideToc entries={toc} />

        </main>
</BaseLayout>

<style>
    .layout-grid { padding: 0; list-style: none; margin: 0 0 24px; }
</style>
