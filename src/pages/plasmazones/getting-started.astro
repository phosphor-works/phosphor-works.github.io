import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import Hljs from "../../components/Hljs.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import "../../styles/home.css";
import "../../styles/hljs.css";
---

<BaseLayout
    title="Getting started — PlasmaZones"
    description="First-run tour for PlasmaZones: verify the install, open the zone editor, and snap your first window."
>
    <Topbar crumb="Getting started" current="plasmazones" />

    <main id="main" class="container pz-sub-page">

        <Breadcrumb href="/plasmazones/" label="PlasmaZones" />

        <PageHero
            title="Getting started"
            tagline="From install to your first snap in about two minutes."
        />

        <section>
            <h2>Verify the install</h2>
            <p class="muted">
                PlasmaZones runs as a user-session daemon
                (<code>plasmazonesd</code>) plus a settings KCM under
                Application Management.  After installing via the
                <a href="/plasmazones/#install">package for your
                distro</a>, log out and back in — or restart the
                daemon — so the shortcuts register.
            </p>
            <pre><code class="language-bash">plasmazonesd --version
# PlasmaZones 2.8.7</code></pre>
            <p class="muted">
                Plasma 6 only.  X11 support was removed in v1.2.0 —
                PlasmaZones is Wayland-native via the layer-shell
                protocol.  XWayland apps still snap, though
                autotile's drag-insert has minor limits under
                XWayland's emulated input reporting.
            </p>
        </section>

        <section>
            <h2>Open the zone editor</h2>
            <p class="muted">
                Press <code>Meta+Shift+E</code>.  The editor opens
                with a sensible default layout for your current
                screen; keep it, pick a different preset, or switch
                to <b>Custom</b> to draw zones freehand.  27
                built-ins ship: Master+Stack, BSP, 3-column grid,
                Fibonacci, portrait / superwide / ultrawide
                variants, priority grid.
            </p>
            <p class="muted">
                Layouts persist as JSON under
                <code>~/.config/plasmazones/</code> with normalized
                0..1 coordinates — the same layout rides along to any
                screen size.  Three files live there:
                <code>config.json</code> (settings),
                <code>assignments.json</code> (per-screen layout +
                quick-layout slots),
                <code>session.json</code> (ephemeral state).
            </p>
        </section>

        <section>
            <h2>Your first snap</h2>
            <ol class="step-list">
                <li>Grab any window's title bar.</li>
                <li>
                    Hold <code>Alt</code> — the zone overlay fades in
                    with the active zones outlined.  The modifier is
                    configurable to Meta, Ctrl+Alt, Alt+Shift,
                    Alt+Meta, or Ctrl+Alt+Meta in
                    Settings › Input.
                </li>
                <li>
                    Drop the window inside a zone.  Release the
                    modifier.  The window resizes to fill the zone
                    exactly.
                </li>
                <li>
                    Drag across two adjacent zones while holding
                    <code>Ctrl+Alt</code> (the default span modifier)
                    to snap across both.
                </li>
            </ol>
            <p class="muted">
                From there, <code>Meta+Ctrl+1</code> …
                <code>Meta+Ctrl+9</code> snap the focused window to
                zones 1…9 directly, and
                <code>Alt+Shift+←/→/↑/↓</code> moves focus between
                zones.  The
                <a href="/plasmazones/shortcuts/">shortcut reference</a>
                lists every default binding.
            </p>
        </section>

        <section>
            <h2>Multiple screens + virtual desktops</h2>
            <p class="muted">
                Each physical monitor has its own layout.  You can
                also subdivide a monitor into up to 10
                <b>virtual screens</b> (unique vs. FancyZones) — each
                with its own layout, autotile state, and settings.
                Swap between them with
                <code>Meta+Ctrl+Shift+←/→/↑/↓</code>.
            </p>
            <p class="muted">
                Per-desktop layouts are assigned in
                <b>System Settings › Application Management ›
                PlasmaZones › Layouts</b>.
            </p>
        </section>

        <section>
            <h2>Customizing</h2>
            <ul class="links">
                <li>
                    <a href="/plasmazones/shortcuts/">Shortcut reference →</a>
                    <span class="muted">Defaults + how to rebind each one via KGlobalAccel.</span>
                </li>
                <li>
                    <a href="/guides/shaders/">Shader authoring guide →</a>
                    <span class="muted">
                        Replace any of the 23 bundled GLSL effects
                        (audio-reactive included) with your own.
                        Drops into
                        <code>~/.local/share/plasmazones/shaders/</code>
                        and hot-reloads.
                    </span>
                </li>
                <li>
                    <a href="/guides/tiling/">Tiling algorithms guide →</a>
                    <span class="muted">
                        Author your own autotile in JavaScript. 24
                        built-ins ship (Master+Stack, BSP, Spiral,
                        Grid, Monocle, …).  Drops into
                        <code>~/.local/share/plasmazones/algorithms/</code>.
                    </span>
                </li>
                <li>
                    <a href="/plasmazones/from-fancyzones/">Coming from FancyZones →</a>
                    <span class="muted">Feature-by-feature map for PowerToys users.</span>
                </li>
            </ul>
        </section>

        <SiteFooter rightHref="/plasmazones/" rightLabel="Back to PlasmaZones" />

    </main>

    <Hljs />
</BaseLayout>

<style>
    .pz-sub-page { padding-top: 32px; }
</style>
