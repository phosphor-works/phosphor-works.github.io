import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import Hljs from "../../components/Hljs.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import "../../styles/home.css";
import "../../styles/guide.css";
import "../../styles/hljs.css";
---

<BaseLayout
    title="Getting started — PlasmaZones"
    description="First-run tour for PlasmaZones: verify the install, open the zone editor, and snap your first window."
>
    <Topbar crumb="Getting started" current="plasmazones" />

    <main id="main" class="container guide pz-sub-page">

        <Breadcrumb href="/plasmazones/" label="PlasmaZones" />

        <PageHero
            title="Getting started"
            tagline="From install to your first snap in about two minutes."
        />

        <section>
            <h2>Verify the install</h2>
            <p>
                PlasmaZones is a user-session daemon
                (<code>plasmazonesd</code>) plus a settings KCM under
                Application Management. Install via the
                <a href="/plasmazones/#install">package for your
                distro</a>, then log out and back in so the shortcuts
                register.
            </p>
            <pre><code class="language-bash">plasmazonesd --version
# PlasmaZones 2.8.7</code></pre>
            <p class="muted">
                Plasma 6 and Wayland only; X11 support was removed in
                v1.2.0. XWayland apps still snap, but autotile's
                drag-insert is flakier there.
            </p>
        </section>

        <section>
            <h2>Open the zone editor</h2>
            <p>
                Press <code>Meta+Shift+E</code>. The editor opens on
                whatever layout is currently assigned to the focused
                screen.
            </p>
            <p>
                Pick a different preset, tweak the gutters, or switch
                to <b>Custom</b> to draw zones freehand. 27 presets
                ship: Master+Stack, BSP, 3-column grid, Fibonacci,
                portrait/superwide/ultrawide variants, priority grid.
            </p>
            <p class="muted">
                Layouts persist as JSON under
                <code>~/.config/plasmazones/</code> with normalized
                0..1 coordinates, so the same layout works at any
                screen size. Three files live there:
                <code>config.json</code> for settings,
                <code>assignments.json</code> for per-screen layouts
                and quick-layout slots,
                <code>session.json</code> for ephemeral state.
            </p>
        </section>

        <section>
            <h2>Your first snap</h2>
            <ol class="step-list">
                <li>Grab any window's title bar.</li>
                <li>
                    Hold <code>Alt</code>. The zone overlay fades in
                    with the active zones outlined. (The modifier is
                    configurable in Settings › Input.)
                </li>
                <li>
                    Drop the window inside a zone and release
                    <code>Alt</code>. It resizes to fill the zone.
                </li>
                <li>
                    Hold <code>Ctrl+Alt</code> while dragging across
                    two adjacent zones to snap across both.
                </li>
            </ol>
            <p>
                <code>Meta+Ctrl+1</code>…<code>Meta+Ctrl+9</code>
                snap the focused window to zones 1–9 directly.
                <code>Alt+Shift+←/→/↑/↓</code> moves focus between
                zones. The <a href="/plasmazones/shortcuts/">shortcut
                reference</a> lists the rest.
            </p>
        </section>

        <section>
            <h2>Multiple screens and virtual desktops</h2>
            <p>
                Each physical monitor has its own layout. You can
                also subdivide a monitor into up to 10
                <b>virtual screens</b>, each with its own layout,
                autotile state, and settings. Swap between them with
                <code>Meta+Ctrl+Shift+←/→/↑/↓</code>.
            </p>
            <p>
                Per-desktop layouts are assigned in
                <b>System Settings › Application Management ›
                PlasmaZones › Layouts</b>.
            </p>
        </section>

        <section>
            <h2>Customizing</h2>
            <ul class="links">
                <li>
                    <a href="/plasmazones/shortcuts/">Shortcut reference →</a>
                    <span class="muted">Every default binding and where to rebind it.</span>
                </li>
                <li>
                    <a href="/guides/shaders/">Shader authoring guide →</a>
                    <span class="muted">
                        Write GLSL for zone highlights and snap
                        previews.  Drops into
                        <code>~/.local/share/plasmazones/shaders/</code>
                        and hot-reloads.
                    </span>
                </li>
                <li>
                    <a href="/guides/tiling/">Tiling algorithms guide →</a>
                    <span class="muted">
                        Write autotile algorithms in JavaScript.
                        Drops into
                        <code>~/.local/share/plasmazones/algorithms/</code>.
                    </span>
                </li>
                <li>
                    <a href="/plasmazones/from-fancyzones/">Coming from FancyZones →</a>
                    <span class="muted">Feature map for PowerToys users.</span>
                </li>
            </ul>
        </section>

        <SiteFooter rightHref="/plasmazones/" rightLabel="Back to PlasmaZones" />

    </main>

    <Hljs />
</BaseLayout>

<style>
    .pz-sub-page { padding-top: 32px; }
</style>
