---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// /plasmazones/ — showcase page for the flagship consumer of the
// Phosphor suite.  Describes what the product is, what it does,
// how to install it, and how it uses the libraries documented
// elsewhere on this site.

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import { Code } from "astro-expressive-code/components";
import HeroLogoDark from "../../components/HeroLogoDark.astro";
import HeroLogoLight from "../../components/HeroLogoLight.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import "../../styles/home.css";

// Screenshot auto-discovery.  Drop a PNG/JPG/WebP into
// src/assets/plasmazones/ with a filename matching the SHOTS/editor
// entries below and the tile auto-swaps from placeholder to a real
// <Image>.  Astro emits width/height/hashed URL at build time.
const screenshotModules = import.meta.glob<{ default: ImageMetadata }>(
    "../../assets/plasmazones/*.{png,jpg,jpeg,webp,avif}",
    { eager: true }
);
const resolveScreenshot = (filename: string): ImageMetadata | undefined => {
    const key = `../../assets/plasmazones/${filename}`;
    return screenshotModules[key]?.default;
};
const heroScreenshot = resolveScreenshot("editor.png");

const jsonLd = {
    "@type": "SoftwareApplication",
    name: "PlasmaZones",
    description: "Zone-based window tiling for KDE Plasma built on the Phosphor library suite.",
    applicationCategory: "DesktopEnhancement",
    operatingSystem: "Linux",
    url: "https://phosphor-works.github.io/plasmazones/",
    downloadUrl: "https://github.com/fuddlesworth/PlasmaZones/releases/latest",
    license: "https://spdx.org/licenses/GPL-3.0-or-later.html",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};

const FEATURES = [
    {
        title: "Drag-to-snap tiling",
        body: "Grab a window, hold a modifier, and drop it into any zone. " +
              "Snap feedback is shader-driven so it reads at a glance without " +
              "feeling busy.",
    },
    {
        title: "Custom zone layouts",
        body: "Design layouts visually in the editor. Zones are named regions " +
              "with appearance and quick-select slots. All coordinates are " +
              "normalized so the same layout works on any screen size.",
    },
    {
        title: "Per-screen, per-virtual-desktop",
        body: "Assign different layouts to each monitor and virtual desktop. " +
              "Quick-layouts bind number keys 1-9 to your favorite layouts for " +
              "fast context switches.",
    },
    {
        title: "Shader effects you actually want on",
        body: "Zone highlights, snap previews, and drag ghosts run through the " +
              "phosphor-rendering multipass ShaderEffect. Ship presets or write " +
              "your own GLSL.",
    },
    {
        title: "Global shortcuts, wherever you are",
        body: "Snap, switch zones, move windows, cycle layouts. Works through " +
              "KGlobalAccel on KDE, XDG Portal on other desktops, or a D-Bus " +
              "fallback.",
    },
    {
        title: "Scriptable tiling algorithms",
        body: "Built-in binary-split, columns, and master-stack are all you " +
              "need for most layouts. Drop in your own JS for anything else.",
    },
];

const WAYS_TO_GET = [
    {
        label: "Arch Linux (AUR)",
        href: "https://aur.archlinux.org/packages/plasmazones-bin",
        note: "Prebuilt binary, or plasmazones for the source package.",
        code: `yay -S plasmazones-bin`,
    },
    {
        label: "Fedora (COPR)",
        href: "https://copr.fedorainfracloud.org/coprs/fuddlesworth/PlasmaZones/",
        note: "Official COPR repo.",
        code: `sudo dnf copr enable fuddlesworth/PlasmaZones
sudo dnf install plasmazones`,
    },
    {
        label: "openSUSE Tumbleweed (OBS)",
        href: "https://build.opensuse.org/package/show/home:ilFrance/plasmazones",
        note: "Community-maintained by ilFrance.",
        code: `sudo zypper addrepo https://download.opensuse.org/repositories/home:ilFrance/openSUSE_Tumbleweed/home:ilFrance.repo
sudo zypper refresh
sudo zypper install plasmazones`,
    },
    {
        label: "Nix",
        href: "https://github.com/fuddlesworth/PlasmaZones#nix",
        note: "Or wire the flake into your inputs.",
        code: `nix profile install github:fuddlesworth/PlasmaZones`,
    },
    {
        label: "Portable tarball",
        href: "https://github.com/fuddlesworth/PlasmaZones/releases/latest",
        note: "Lands in ~/.local. Best for Fedora Atomic or no-root environments.",
        code: `curl -L -o plasmazones.tar.gz \\
  https://github.com/fuddlesworth/PlasmaZones/releases/latest/download/plasmazones-linux-x86_64.tar.gz
tar xzf plasmazones.tar.gz
cd plasmazones-linux-x86_64 && ./install.sh`,
    },
    {
        label: "Build from source",
        href: "https://github.com/fuddlesworth/PlasmaZones#building-from-source",
        note: "Needs Qt 6.6+, KF6, CMake 3.16+, a C++20 compiler, wayland-scanner.",
        code: `git clone https://github.com/fuddlesworth/PlasmaZones.git
cd PlasmaZones
cmake -B build -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr
cmake --build build -j$(nproc)
sudo cmake --install build`,
    },
];

// Screenshot gallery.  Drop files into public/plasmazones/ with these
// exact names; tiles become live the moment the image exists.  Order
// is overview → interaction → configuration → customization.
const SHOTS = [
    {
        file: "snap-preview.png",
        title: "Snap preview",
        caption: "A shader-driven drop target while dragging that reads at a glance without flashing.",
    },
    {
        file: "zone-highlights.png",
        title: "Active zones",
        caption: "Zone outlines fade in on modifier and fade out on release, so nothing sits on screen when you don't need it.",
    },
    {
        file: "multi-desktop.png",
        title: "Per-screen, per-desktop",
        caption: "Assign a different layout to each monitor and virtual desktop; quick-layouts bind 1–9.",
    },
    {
        file: "shaders.png",
        title: "Shader presets",
        caption: "Multipass ShaderEffect with presets you can swap, tweak, or replace with your own GLSL.",
    },
    {
        file: "tiling-algos.png",
        title: "Tiling algorithms",
        caption: "Binary-split, columns, and master-stack ship built in, with a JS sandbox for anything custom.",
    },
    {
        file: "shortcuts.png",
        title: "Global shortcuts",
        caption: "Snap, switch zones, and cycle layouts via KGlobalAccel, XDG Portal, or a D-Bus fallback.",
    },
];

// Libraries consumed by PlasmaZones (all of them, but the page calls out
// what each one contributes at the product level).
const CONSUMED = [
    { slug: "zones",      role: "Layout model + JSON persistence" },
    { slug: "tiles",      role: "Tiling algorithms" },
    { slug: "shell",      role: "Wayland layer-shell overlays" },
    { slug: "rendering",  role: "Multipass shader effects" },
    { slug: "animation",  role: "Snap and fade motion curves" },
    { slug: "shortcuts",  role: "Global keyboard shortcuts" },
    { slug: "identity",   role: "Stable window handles" },
    { slug: "layer",      role: "Overlay surface config" },
    { slug: "layout-api", role: "Layout-producer interfaces" },
    { slug: "config",     role: "Configuration backend" },
];
---

<BaseLayout
    title="PlasmaZones — Zone-based window tiling for KDE Plasma"
    description="PlasmaZones: a zone-based window tiler for KDE Plasma built on the Phosphor library suite."
    jsonLd={jsonLd}
>
    <Topbar crumb="PlasmaZones" current="plasmazones" />

    <main id="main" class="container pz-page">

        <header class="pz-hero gradient-overlay">
            <HeroLogoDark class="logo" />
            <HeroLogoLight class="logo" />
            <div class="pz-hero-text">
                <h1>PlasmaZones</h1>
                <p class="tagline">Zone-based window tiling for KDE Plasma.</p>
                <p class="blurb">
                    Define named regions on your screen, drag windows into them,
                    and get a layout that actually fits the way you work. Built
                    on the <a href="/libraries/">Phosphor library suite</a>;
                    scriptable, themeable, Wayland-native.
                </p>
                <div class="pz-hero-ctas">
                    <a class="pz-cta primary" href="https://github.com/fuddlesworth/PlasmaZones">Source →</a>
                    <a class="pz-cta" href="#install">Install</a>
                </div>
            </div>
        </header>

        <!-- Hero screenshot.  Drop src/assets/plasmazones/editor.png
             to replace the placeholder automatically.  Astro optimizes
             and emits width/height for CLS-safe rendering. -->
        <section class="pz-screens">
            <figure class="pz-screen pz-screen-hero card-surface">
                {heroScreenshot
                    ? <Image src={heroScreenshot} alt="PlasmaZones layout editor" loading="eager" />
                    : <div class="pz-screen-placeholder">
                        <span>Hero screenshot</span>
                        <small>src/assets/plasmazones/editor.png</small>
                    </div>
                }
                <figcaption>
                    The layout editor. Named zones designed visually, with
                    normalized coordinates so the same layout works at any
                    screen size.
                </figcaption>
            </figure>
        </section>

        <section>
            <h2>Features</h2>
            <div class="pz-features card-grid">
                {FEATURES.map(f => (
                    <article class="pz-feature card-surface">
                        <h3>{f.title}</h3>
                        <p>{f.body}</p>
                    </article>
                ))}
            </div>
        </section>

        <section>
            <h2>See it in action</h2>
            <p class="muted">
                Tiles auto-swap placeholder → real image as soon as the
                PNG lands under <code>src/assets/plasmazones/</code>
                with the listed filename. No code edit needed.
            </p>
            <div class="pz-gallery card-grid">
                {SHOTS.map(s => {
                    const img = resolveScreenshot(s.file);
                    return (
                        <figure class="pz-shot card-surface">
                            {img
                                ? <Image src={img} alt={s.title} loading="lazy" />
                                : <div class="pz-screen-placeholder">
                                    <span>{s.title}</span>
                                    <small>src/assets/plasmazones/{s.file}</small>
                                </div>
                            }
                            <figcaption>
                                <strong>{s.title}</strong>
                                <span>{s.caption}</span>
                            </figcaption>
                        </figure>
                    );
                })}
            </div>
        </section>

        <section id="install">
            <h2>Install</h2>
            <div class="pz-install card-grid">
                {WAYS_TO_GET.map(w => (
                    <article class="pz-install-method card-surface">
                        <header>
                            <a href={w.href}>{w.label} →</a>
                            <span>{w.note}</span>
                        </header>
                        <Code lang="bash" code={w.code} wrap />
                    </article>
                ))}
            </div>
        </section>

        <section>
            <h2>Learn</h2>
            <ul class="links">
                <li>
                    <a href="/plasmazones/getting-started/">Getting started →</a>
                    <span class="muted">A first-run tour from verifying the install to snapping your first window.</span>
                </li>
                <li>
                    <a href="/plasmazones/shortcuts/">Keyboard shortcuts →</a>
                    <span class="muted">Default bindings and how to rebind each one.</span>
                </li>
                <li>
                    <a href="/plasmazones/from-fancyzones/">Coming from FancyZones →</a>
                    <span class="muted">Feature-by-feature map for the PowerToys → Plasma jump.</span>
                </li>
            </ul>
        </section>

        <section>
            <h2>Extend it</h2>
            <p class="muted">
                PlasmaZones has two first-class extension points. Custom
                content goes in <code>~/.local/share/plasmazones/</code> and
                hot-reloads.
            </p>
            <ul class="links">
                <li>
                    <a href="/guides/shaders/">Shader authoring guide →</a>
                    <span class="muted">GLSL 450 uniform contract, metadata schema, audio reactivity, multipass.</span>
                </li>
                <li>
                    <a href="/guides/tiling/">Tiling algorithm guide →</a>
                    <span class="muted">JavaScript sandbox contract, metadata tags, built-in helpers, hot-reload.</span>
                </li>
            </ul>
        </section>

        <section>
            <h2>Built on Phosphor</h2>
            <p class="muted">
                Every major subsystem is its own library. Fixes land once and
                reach every consumer, and third-party code can depend on only
                the pieces it needs.
            </p>
            <ul class="pz-consumed card-grid">
                {CONSUMED.map(c => (
                    <li class="card-surface">
                        <a href={`/libraries/${c.slug}/`}>
                            <code>phosphor-{c.slug}</code>
                        </a>
                        <span>{c.role}</span>
                    </li>
                ))}
            </ul>
        </section>

        <SiteFooter note="PlasmaZones · GPL-3.0-or-later" />

    </main>
</BaseLayout>

<style>
    .pz-page { padding-top: 32px; }

    /* .pz-hero layers on top of .gradient-overlay (from home.css) for
       the tinted-gradient look; everything here is layout-only. */
    .pz-hero {
        display: flex;
        align-items: center;
        gap: 36px;
        padding: 40px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--card);
        margin-bottom: 40px;
    }
    /* Hero logo size/filter comes from home.css's .logo rule (global
       import).  A scoped .pz-hero-logo here wouldn't reach the SVG
       because Astro scoped styles don't cross component boundaries —
       HeroLogoDark is a separate component, so its root <svg> ignores
       classes scoped to this page. */
    .pz-hero-text h1 {
        margin: 0 0 8px;
        font-size: 44px;
    }
    .pz-hero-ctas {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }
    .pz-cta {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid var(--border);
        color: var(--fg);
        background: var(--card-high);
    }
    .pz-cta.primary {
        background: var(--link);
        color: var(--on-primary);
        border-color: var(--link);
    }
    .pz-cta.primary:hover { background: var(--link-hover); }
    .pz-cta:hover { border-color: var(--link); color: var(--link); }

    @media (max-width: 640px) {
        .pz-hero { flex-direction: column; align-items: flex-start; gap: 24px; padding: 32px; }
        /* .logo 80x80 override on narrow screens comes from home.css. */
        .pz-hero-text h1 { font-size: 34px; }
    }

    .pz-screens { margin-bottom: 48px; }
    /* .pz-screen and .pz-shot both compose .card-surface; only the
       overflow and figure-reset live here. */
    .pz-screen,
    .pz-shot {
        margin: 0;
        overflow: hidden;
    }
    .pz-screen img,
    .pz-shot img { display: block; width: 100%; height: auto; }
    .pz-screen figcaption,
    .pz-shot figcaption {
        padding: 12px 16px;
        border-top: 1px solid var(--border);
        font-size: 13px;
        color: var(--fg-dim);
        line-height: 1.55;
    }
    .pz-shot figcaption {
        display: flex;
        flex-direction: column;
        gap: 4px;
        font-size: 12.5px;
    }
    .pz-shot figcaption strong {
        color: var(--fg);
        font-size: 13.5px;
        font-weight: 600;
    }
    .pz-screen-placeholder {
        aspect-ratio: 16 / 9;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--fg-muted);
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 13px;
        gap: 6px;
        background:
            linear-gradient(135deg, rgba(59,130,246,0.06), rgba(168,85,247,0.06)),
            var(--card);
    }
    .pz-screen-placeholder small { font-size: 11px; opacity: 0.7; }

    .pz-gallery { margin-top: 16px; }

    .pz-features { --card-grid-min: 280px; }
    .pz-feature {
        padding: 18px 20px;
    }
    .pz-feature h3 {
        margin: 0 0 8px;
        font-size: 15px;
        color: var(--fg);
    }
    .pz-feature p {
        margin: 0;
        font-size: 13px;
        color: var(--fg-dim);
        line-height: 1.6;
    }

    .pz-install { --card-grid-min: 360px; }
    .pz-install-method {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .pz-install-method header {
        padding: 14px 16px 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .pz-install-method header a {
        color: var(--link);
        font-weight: 600;
        text-decoration: none;
        font-size: 14px;
    }
    .pz-install-method header a:hover { text-decoration: underline; }
    .pz-install-method header span {
        color: var(--fg-dim);
        font-size: 12px;
    }
    /* Make the Expressive Code block sit flush inside the install card.
       EC's default frame draws its own border / radius, which would
       stack with the card's outer .card-surface border and leave a
       visible "box-in-a-box".  Neutralizing EC's frame here lets the
       code block extend edge-to-edge with just a single top divider
       from the card header, matching the old hljs rendering.  The
       `wrap` prop on <Code> handles long URLs (openSUSE zypper
       addrepo, Portable-tarball curl) without horizontal scroll.
       :global() is needed because EC's .expressive-code div isn't
       rendered by this Astro component's template, so the scoped
       data-astro-cid-* attribute isn't applied to it. */
    .pz-install-method :global(.expressive-code) {
        flex: 1;
        border-top: 1px solid var(--border);
    }
    .pz-install-method :global(.expressive-code pre) {
        border-radius: 0;
        border: 0;
    }

    .pz-consumed {
        --card-grid-min: 280px;
        gap: 8px;
    }
    .pz-consumed li {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 12px 14px;
        border-radius: var(--radius-sm);
    }
    .pz-consumed code {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 13px;
        font-weight: 600;
        color: var(--link);
        background: none;
        padding: 0;
    }
    .pz-consumed span {
        color: var(--fg-dim);
        font-size: 12px;
    }
</style>
