//
// Keyboard shortcut reference for PlasmaZones.  Scaffold only —
// every <td>FILL</td> placeholder needs to be replaced with the
// actual default binding from the PlasmaZones source.  Keep the
// table structure so adding a new shortcut is a one-line edit.

import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import "../../styles/home.css";
import "../../styles/guide.css";

interface Shortcut {
    binding: string;
    action: string;
    note?: string;
}

const DRAG_SNAP: Shortcut[] = [
    { binding: "FILL",  action: "Show zone overlay while dragging" },
    { binding: "FILL",  action: "Snap window to zone under cursor" },
    { binding: "FILL",  action: "Cancel in-flight drag without snapping" },
];

const ZONE_NAV: Shortcut[] = [
    { binding: "FILL",  action: "Move focused window to next zone" },
    { binding: "FILL",  action: "Move focused window to previous zone" },
    { binding: "FILL",  action: "Focus window in zone 1", note: "1–9 — focus window per zone index" },
    { binding: "FILL",  action: "Toggle zone overlay (no drag)" },
];

const LAYOUT: Shortcut[] = [
    { binding: "FILL",  action: "Cycle to next layout on current screen" },
    { binding: "FILL",  action: "Cycle to previous layout" },
    { binding: "FILL",  action: "Load quick-layout 1",
      note: "1–9 — load one of the quick-layout slots" },
    { binding: "FILL",  action: "Open layout editor" },
];

const MISC: Shortcut[] = [
    { binding: "FILL",  action: "Open PlasmaZones settings" },
    { binding: "FILL",  action: "Reload configuration from disk" },
    { binding: "FILL",  action: "Toggle autotile on current screen" },
];
---

<BaseLayout
    title="Shortcuts — PlasmaZones"
    description="Default keyboard shortcuts for PlasmaZones: drag-snap, zone navigation, layout cycling, and settings."
>
    <Topbar crumb="Shortcuts" current="plasmazones" />

    <main id="main" class="container guide">

        <nav class="lib-breadcrumb" aria-label="Breadcrumb">
            <a href="/plasmazones/">← PlasmaZones</a>
        </nav>

        <PageHero
            title="Keyboard shortcuts"
            tagline="Default bindings; all remappable in System Settings › Shortcuts."
        >
            <p class="muted">
                Shortcuts are registered through
                <a href="/libraries/shortcuts/"><code>phosphor-shortcuts</code></a>
                — KGlobalAccel on KDE, XDG Portal elsewhere, D-Bus as fallback.
                Settings are keyed by action name; rebinding one never
                changes another.
            </p>
        </PageHero>

        <section>
            <h2>Drag to snap</h2>
            <table>
                <thead>
                    <tr><th>Action</th><th>Default</th></tr>
                </thead>
                <tbody>
                    {DRAG_SNAP.map(s => (
                        <tr>
                            <td>{s.action}{s.note && <><br/><span class="muted">{s.note}</span></>}</td>
                            <td><code>{s.binding}</code></td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </section>

        <section>
            <h2>Zone focus + movement</h2>
            <table>
                <thead>
                    <tr><th>Action</th><th>Default</th></tr>
                </thead>
                <tbody>
                    {ZONE_NAV.map(s => (
                        <tr>
                            <td>{s.action}{s.note && <><br/><span class="muted">{s.note}</span></>}</td>
                            <td><code>{s.binding}</code></td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </section>

        <section>
            <h2>Layouts</h2>
            <table>
                <thead>
                    <tr><th>Action</th><th>Default</th></tr>
                </thead>
                <tbody>
                    {LAYOUT.map(s => (
                        <tr>
                            <td>{s.action}{s.note && <><br/><span class="muted">{s.note}</span></>}</td>
                            <td><code>{s.binding}</code></td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </section>

        <section>
            <h2>Miscellaneous</h2>
            <table>
                <thead>
                    <tr><th>Action</th><th>Default</th></tr>
                </thead>
                <tbody>
                    {MISC.map(s => (
                        <tr>
                            <td>{s.action}</td>
                            <td><code>{s.binding}</code></td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </section>

        <section>
            <h2>Rebinding</h2>
            <p>
                Every action's default lives in the PlasmaZones source at
                <code>FILL: data/shortcuts/defaults.json</code>.  Users
                override per-action via KDE System Settings › Keyboard ›
                Shortcuts → <b>PlasmaZones</b>, which writes to
                <code>~/.config/kglobalshortcutsrc</code>.  The override
                takes effect the next time
                <a href="/libraries/shortcuts/"><code>phosphor-shortcuts</code></a>
                reloads (on the next PlasmaZones start, or via the
                "Reload configuration" shortcut above).
            </p>
        </section>

        <SiteFooter rightHref="/plasmazones/" rightLabel="Back to PlasmaZones" />

    </main>
</BaseLayout>

<style>
    .lib-breadcrumb { margin: 0 0 16px; font-size: 13px; }
    .lib-breadcrumb a { color: var(--fg-dim); text-decoration: none; }
    .lib-breadcrumb a:hover { color: var(--link); }
</style>
