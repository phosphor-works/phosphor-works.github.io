//
// Keyboard shortcut reference for PlasmaZones.
// Defaults sourced from src/config/configdefaults.h:1096-1353 and
// src/daemon/shortcutmanager.cpp in the PlasmaZones repo.

import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import PageHero from "../../components/PageHero.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import "../../styles/home.css";

interface Shortcut {
    binding: string;
    action: string;
    note?: string;
}

const CORE: Shortcut[] = [
    { binding: "Meta+Shift+E",    action: "Open zone editor" },
    { binding: "Meta+Shift+P",    action: "Open settings" },
    { binding: "Meta+Alt+[",      action: "Previous layout on current screen" },
    { binding: "Meta+Alt+]",      action: "Next layout on current screen" },
    { binding: "Meta+Alt+Space",  action: "Open layout picker" },
    { binding: "Meta+Ctrl+L",     action: "Toggle layout lock" },
    { binding: "Meta+Ctrl+Z",     action: "Reapply current layout" },
];

const FOCUS_MOVE: Shortcut[] = [
    { binding: "Alt+Shift+←/→/↑/↓",           action: "Focus window in adjacent zone" },
    { binding: "Meta+Alt+Shift+←/→/↑/↓",      action: "Move focused window into adjacent zone" },
    { binding: "Meta+Ctrl+Alt+←/→/↑/↓",       action: "Swap focused window with window in adjacent zone" },
    { binding: "Meta+Alt+, / Meta+Alt+.",     action: "Cycle focused window backward / forward through zones" },
    { binding: "Meta+Ctrl+] / Meta+Ctrl+[",   action: "Rotate all windows clockwise / counter-clockwise within current layout" },
    { binding: "Meta+Alt+Return",             action: "Push focused window to the nearest empty zone" },
    { binding: "Meta+Alt+Escape",             action: "Restore focused window to its pre-snap size" },
    { binding: "Meta+F",                      action: "Toggle focused window's floating state" },
];

const SNAP: Shortcut[] = [
    { binding: "Meta+Ctrl+1 … Meta+Ctrl+9",   action: "Snap focused window to zone 1…9 on current screen" },
    { binding: "Meta+Ctrl+S",                 action: "Snap every visible window to its best-fit zone" },
];

const LAYOUT: Shortcut[] = [
    { binding: "Meta+Alt+1 … Meta+Alt+9",     action: "Load quick-layout slot 1…9",
      note: "Slots are defined in ~/.config/plasmazones/assignments.json; assign in the layout picker." },
];

const AUTOTILE: Shortcut[] = [
    { binding: "Meta+Shift+T",        action: "Toggle autotile on the current screen" },
    { binding: "Meta+Shift+M",        action: "Focus the master window" },
    { binding: "Meta+Shift+Return",   action: "Swap focused window with master" },
    { binding: "Meta+Shift+L / Meta+Shift+H", action: "Increase / decrease master ratio" },
    { binding: "Meta+Shift+] / Meta+Shift+[", action: "Increase / decrease master count" },
    { binding: "Meta+Ctrl+R",         action: "Retile all windows" },
];

const VIRTUAL_SCREEN: Shortcut[] = [
    { binding: "Meta+Ctrl+Shift+←/→/↑/↓",     action: "Swap virtual screens in that direction",
      note: "Virtual screens subdivide a physical monitor into 2–10 logical workspaces, each with its own layout." },
    { binding: "Meta+Ctrl+Shift+] / Meta+Ctrl+Shift+[",
      action: "Rotate virtual screens clockwise / counter-clockwise" },
];

const SECTIONS: { title: string; subtitle?: string; rows: Shortcut[] }[] = [
    { title: "Core",
      rows: CORE },
    { title: "Zone focus + movement",
      rows: FOCUS_MOVE },
    { title: "Snap",
      rows: SNAP },
    { title: "Layouts",
      rows: LAYOUT },
    { title: "Autotile",
      subtitle: "Off by default.  Enable per-screen, then pick an algorithm (Master+Stack, BSP, Spiral, Grid, Monocle — 24 built-ins + custom JS hot-reload) in Settings.",
      rows: AUTOTILE },
    { title: "Virtual screens",
      rows: VIRTUAL_SCREEN },
];
---

<BaseLayout
    title="Shortcuts — PlasmaZones"
    description="Default keyboard shortcuts for PlasmaZones: drag-snap, zone navigation, layout cycling, autotile, and virtual screens."
>
    <Topbar crumb="Shortcuts" current="plasmazones" />

    <main id="main" class="container pz-sub-page page-prose">

        <Breadcrumb href="/plasmazones/" label="PlasmaZones" />

        <PageHero
            title="Keyboard shortcuts"
            tagline="Default bindings; all remappable in System Settings › Shortcuts › PlasmaZones."
        >
            <p class="muted">
                Shortcuts are registered through
                <a href="/libraries/shortcuts/"><code>phosphor-shortcuts</code></a>
                — KGlobalAccel (component key <code>plasmazonesd</code>)
                on KDE, XDG Portal fallback when built with
                <code>-DUSE_KDE_FRAMEWORKS=OFF</code>. Settings are
                keyed by action ID, so rebinding one never touches
                another.
            </p>
        </PageHero>

        <section>
            <h2>Drag to snap</h2>
            <p class="muted" style="margin-bottom:14px">
                The drag and span modifiers aren't keyboard shortcuts —
                they're settings.  Hold the drag modifier while moving
                a window to pop the zone overlay; hold the span modifier
                over two adjacent zones to snap across both.
            </p>
            <ul class="shortcut-list">
                <li class="card-surface">
                    <span class="shortcut-action">
                        Drag modifier
                        <span class="shortcut-note">
                            Configurable to Meta, Ctrl+Alt, Alt+Shift,
                            Alt+Meta, or Ctrl+Alt+Meta.
                        </span>
                    </span>
                    <code class="shortcut-binding">Alt</code>
                </li>
                <li class="card-surface">
                    <span class="shortcut-action">
                        Zone-span modifier
                        <span class="shortcut-note">
                            Hold while dragging across two adjacent
                            zones to snap across both.
                        </span>
                    </span>
                    <code class="shortcut-binding">Ctrl+Alt</code>
                </li>
            </ul>
        </section>

        {SECTIONS.map(s => (
            <section>
                <h2>{s.title}</h2>
                {s.subtitle && <p class="muted" style="margin-bottom:14px">{s.subtitle}</p>}
                <ul class="shortcut-list">
                    {s.rows.map(r => (
                        <li class="card-surface">
                            <span class="shortcut-action">
                                {r.action}
                                {r.note && <span class="shortcut-note">{r.note}</span>}
                            </span>
                            <code class="shortcut-binding">{r.binding}</code>
                        </li>
                    ))}
                </ul>
            </section>
        ))}

        <section>
            <h2>Rebinding</h2>
            <p class="muted">
                Every action has a stable ID assigned by
                <a href="/libraries/shortcuts/"><code>phosphor-shortcuts</code></a>'s
                <code>ShortcutManager</code>
                (see <code>src/daemon/shortcutmanager.cpp</code> in the
                PlasmaZones source).  Users rebind per-action via
                System Settings › Keyboard › Shortcuts →
                <b>PlasmaZones</b>, which writes to
                <code>~/.config/kglobalshortcutsrc</code>.  Overrides
                take effect the next time the daemon reloads (on
                PlasmaZones start, or after the
                <code>Meta+Ctrl+Z</code> "Reapply layout" shortcut
                above).
            </p>
        </section>

        <SiteFooter rightHref="/plasmazones/" rightLabel="Back to PlasmaZones" />

    </main>
</BaseLayout>

<style>
    .pz-sub-page { padding-top: 32px; }
</style>
