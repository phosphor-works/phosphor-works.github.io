//
// Drop this into any page that has prose <pre><code> blocks.  It
// registers just the languages Phosphor documentation actually uses
// (bash, glsl, cpp, javascript, json) and highlights every code
// block on DOMContentLoaded.  Phosphor-themed token colors come from
// src/styles/hljs.css which is imported globally by any page using
// this component.
//
// Add `class="language-<name>"` to the inner <code> to force a
// language.  Otherwise hljs auto-detects.
---

<script>
    import hljs from "highlight.js/lib/core";
    import bash from "highlight.js/lib/languages/bash";
    import cpp from "highlight.js/lib/languages/cpp";
    import glsl from "highlight.js/lib/languages/glsl";
    import javascript from "highlight.js/lib/languages/javascript";
    import json from "highlight.js/lib/languages/json";

    hljs.registerLanguage("bash", bash);
    hljs.registerLanguage("cpp", cpp);
    hljs.registerLanguage("glsl", glsl);
    hljs.registerLanguage("javascript", javascript);
    hljs.registerLanguage("json", json);

    // Highlight every <pre><code> on the page.  Skip blocks that are
    // already highlighted (this script is idempotent so navigating
    // between Astro view transitions doesn't re-wrap DOM nodes) and
    // skip ones explicitly opted out with `data-nohljs`.
    const highlight = () => {
        document.querySelectorAll("pre code").forEach((el) => {
            const element = el as HTMLElement;
            if (element.dataset.highlighted === "yes") return;
            if (element.dataset.nohljs !== undefined) return;
            hljs.highlightElement(element);
        });
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", highlight);
    } else {
        highlight();
    }
</script>
