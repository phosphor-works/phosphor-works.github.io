---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Sticky topbar shared across the umbrella site and (via docs/header.html)
// the Doxygen-generated API reference.  The inner-square <rect> carries
// `class="pz-topbar-inner"` so the palette page's preview.dark.css /
// preview.light.css can flip it between --brand-navy and tinted-white.
//
// Tier-1 sections live in LINKS below.  Pass `current` to hide the
// active section's link (keeps the bar from rendering a self-link
// that lands you on the page you're already viewing).  The section
// order should match the doxygen topbar in docs/header.html so
// readers see the same layout across the two rendering paths.

interface Props {
    crumb: string;
    current?: "plasmazones" | "libraries" | "guides" | "api" | "brand" | "palette" | "about";
    homeHref?: string;
    githubHref?: string;
}

const {
    crumb,
    current,
    homeHref = "/",
    githubHref = "https://github.com/phosphor-works",
} = Astro.props;

import SiteSearch from "./SiteSearch.astro";
import ThemeToggle from "./ThemeToggle.astro";

const LINKS = [
    { key: "plasmazones", label: "PlasmaZones", href: "/plasmazones/" },
    { key: "libraries",   label: "Libraries",   href: "/libraries/"   },
    { key: "guides",      label: "Guides",      href: "/guides/"      },
    { key: "api",         label: "API",         href: "/api/"         },
    { key: "brand",       label: "Brand",       href: "/brand/"       },
    { key: "palette",     label: "Palette",     href: "/palette/"     },
    { key: "about",       label: "About",       href: "/about/"       },
];
---

<nav class="pz-topbar" aria-label="Primary">
    <a class="pz-home" href={homeHref}>
        <!-- Phosphor Φ mark tuned for 22×22 rendering — fatter stroke
             than the full-size SVG so the Φ reads at favicon scale. -->
        <svg width="22" height="22" viewBox="96 96 832 832" xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true">
            <defs>
                <linearGradient id="pz-topbar-g" x1="120" y1="120" x2="904" y2="904" gradientUnits="userSpaceOnUse">
                    <stop offset="0"    stop-color="#22D3EE"/>
                    <stop offset="0.45" stop-color="#3B82F6"/>
                    <stop offset="0.75" stop-color="#A855F7"/>
                    <stop offset="1"    stop-color="#F43F5E"/>
                </linearGradient>
                <linearGradient id="pz-topbar-phi" x1="300" y1="240" x2="724" y2="784" gradientUnits="userSpaceOnUse">
                    <stop offset="0"    stop-color="#22D3EE"/>
                    <stop offset="0.55" stop-color="#A855F7"/>
                    <stop offset="1"    stop-color="#F43F5E"/>
                </linearGradient>
            </defs>
            <rect x="96" y="96" width="832" height="832" rx="190" fill="url(#pz-topbar-g)"/>
            <rect class="pz-topbar-inner" x="180" y="180" width="664" height="664" rx="120"/>
            <line x1="512" y1="290" x2="512" y2="734" stroke="url(#pz-topbar-phi)" stroke-width="62" stroke-linecap="round"/>
            <circle cx="512" cy="512" r="130" stroke="url(#pz-topbar-phi)" stroke-width="62" fill="none"/>
        </svg>
        <span>Phosphor</span>
    </a>
    <span class="pz-sep">/</span>
    <span class="pz-crumb">{crumb}</span>
    <div class="pz-spacer"></div>
    <SiteSearch />

    {/* Inline link bar — wide screens.  Hidden via CSS @ ≤720px in
        favour of the .pz-menu drawer below. */}
    <div class="pz-links">
        {LINKS.filter(l => l.key !== current).map(l => (
            <a class="pz-link" href={l.href}>{l.label}</a>
        ))}
        <a class="pz-link" href={githubHref}>GitHub</a>
    </div>

    <ThemeToggle />

    {/* Hamburger drawer — narrow screens.  Pure-CSS using <details>:
        no JS framework, no aria-toggle wiring, the browser handles
        keyboard and a11y.  Hidden via CSS @ >720px so wide screens
        keep the inline link bar above. */}
    <details class="pz-menu">
        <summary class="pz-menu-toggle" aria-label="Open navigation menu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="pz-menu-icon-open">
                <line x1="3" y1="6"  x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="pz-menu-icon-close">
                <line x1="18" y1="6"  x2="6"  y2="18"/>
                <line x1="6"  y1="6"  x2="18" y2="18"/>
            </svg>
        </summary>
        <div class="pz-menu-panel">
            {LINKS.filter(l => l.key !== current).map(l => (
                <a class="pz-menu-link" href={l.href}>{l.label}</a>
            ))}
            <a class="pz-menu-link" href={githubHref}>GitHub</a>
        </div>
    </details>
</nav>
