---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Topbar search powered by Pagefind.  Index is built at
// `dist/pagefind/` by astro-pagefind's post-build hook (integration
// in astro.config.mjs).  This component is a thin <input> + <dialog>
// shell; the actual search is driven by ./src/scripts/search.ts.
---

<div class="site-search">
    <button
        type="button"
        class="site-search-trigger"
        aria-label="Search site"
        aria-keyshortcuts="/"
    >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m21 21-4.3-4.3"></path>
        </svg>
        <span class="site-search-label">Search</span>
        <kbd class="site-search-kbd">/</kbd>
    </button>

    <dialog class="site-search-dialog" aria-label="Site search">
        <form method="dialog" class="site-search-form">
            <input
                type="search"
                class="site-search-input"
                placeholder="Search documentation…"
                autocomplete="off"
                spellcheck="false"
                aria-label="Search query"
            />
            <button type="submit" class="site-search-close" aria-label="Close search">Esc</button>
        </form>
        <div class="site-search-results" role="listbox" aria-label="Search results"></div>
    </dialog>
</div>

<script>
    import { initSearch } from "../scripts/search";
    // Re-bind on every navigation — see ThemeToggle.astro for the
    // ViewTransitions rationale.
    document.addEventListener("astro:page-load", () => initSearch());
</script>

<style>
    .site-search { display: inline-block; }
    .site-search-trigger {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 4px 10px 4px 8px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--fg-dim);
        font: inherit;
        font-size: 12px;
        cursor: pointer;
        transition: border-color 0.15s ease, color 0.15s ease;
    }
    .site-search-trigger:hover { border-color: var(--link); color: var(--fg); }
    .site-search-label { line-height: 1; }
    .site-search-kbd {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        padding: 1px 5px;
        border: 1px solid var(--border);
        border-radius: var(--radius-xs);
        background: var(--card-high);
        color: var(--fg-dim);
    }
    @media (max-width: 640px) {
        .site-search-label, .site-search-kbd { display: none; }
    }

    /* Don't set display on the base selector — the UA style for
       `<dialog>` uses display:none until [open] is set, and
       overriding that unconditionally kept the dialog visible all
       the time (which ALSO blocked Esc-to-close, because it never
       entered top-layer modal state). */
    .site-search-dialog {
        width: min(640px, 100vw - 32px);
        max-height: min(75vh, 640px);
        margin: 10vh auto auto;
        padding: 0;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: var(--card);
        color: var(--fg);
        overflow: hidden;
        flex-direction: column;
    }
    .site-search-dialog[open] {
        display: flex;
    }
    .site-search-dialog::backdrop {
        background: color-mix(in srgb, var(--brand-void) 70%, transparent);
        backdrop-filter: blur(4px);
    }

    .site-search-form {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-bottom: 1px solid var(--border);
    }
    .site-search-input {
        flex: 1;
        padding: 8px 10px;
        background: transparent;
        border: 0;
        color: var(--fg);
        font: inherit;
        font-size: 15px;
        outline: none;
    }
    .site-search-close {
        padding: 4px 8px;
        background: var(--card-high);
        border: 1px solid var(--border);
        border-radius: var(--radius-xs);
        color: var(--fg-dim);
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        cursor: pointer;
    }

    .site-search-results {
        flex: 1;
        overflow-y: auto;
        padding: 4px;
    }
    .site-search-results :global(.result) {
        display: block;
        padding: 10px 12px;
        border-radius: var(--radius-sm);
        text-decoration: none;
        color: var(--fg);
    }
    .site-search-results :global(.result:hover),
    .site-search-results :global(.result[aria-selected="true"]) {
        background: var(--card-high);
        outline: 1px solid var(--border);
    }
    .site-search-results :global(.result-title) {
        display: block;
        font-weight: 600;
        color: var(--link);
        margin-bottom: 3px;
    }
    .site-search-results :global(.result-excerpt) {
        display: block;
        font-size: 13px;
        color: var(--fg-dim);
        line-height: 1.45;
    }
    .site-search-results :global(.result-excerpt mark) {
        background: color-mix(in srgb, var(--link) 30%, transparent);
        color: var(--fg);
        padding: 0 2px;
        border-radius: 2px;
    }
    .site-search-results :global(.empty) {
        padding: 20px;
        color: var(--fg-muted);
        font-size: 13px;
        text-align: center;
    }
</style>
