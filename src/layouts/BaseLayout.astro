---
// SPDX-FileCopyrightText: 2026 fuddlesworth
// SPDX-License-Identifier: GPL-3.0-or-later
//
// Shared HTML shell — <head>, fonts, favicons, OG/Twitter meta.
// Individual pages bring their own <main> and any page-scoped
// stylesheets (e.g. the palette page swaps /palette/preview.{dark,
// light}.css at runtime).

interface Props {
    title: string;
    description?: string;
    /** Page-specific OG image (relative path).  Defaults to the
     *  site-wide /og-image.svg brand card. */
    ogImage?: string;
    /** Extra JSON-LD structured-data nodes to inject inside the
     *  main <script type="application/ld+json"> graph.  The page
     *  provides the @type-specific part; BaseLayout provides the
     *  Organization root node. */
    jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, ogImage = "/og-image.svg", jsonLd } = Astro.props;

// Astro.site is set in astro.config.mjs → "https://phosphor-works.github.io".
// Resolve every OG URL to absolute form so share scrapers (Mastodon,
// Discord, Slack) don't choke on relative paths.
const siteRoot = Astro.site ?? new URL("https://phosphor-works.github.io");
const canonical = new URL(Astro.url.pathname, siteRoot).toString();
const absoluteOgImage = new URL(ogImage, siteRoot).toString();
const metaDescription = description ??
    "Phosphor — Qt6 and Wayland libraries for window-management tools.";

// JSON-LD graph.  Every page emits the Organization node (baseline
// entity for search engines to group pages under).  Page-specific
// nodes (SoftwareSourceCode, SoftwareApplication) come in via the
// `jsonLd` prop and get flattened into the @graph array.
const organization = {
    "@type": "Organization",
    "@id": `${siteRoot.origin}/#org`,
    name: "Phosphor Works",
    url: siteRoot.origin,
    logo: `${siteRoot.origin}/favicon.svg`,
    sameAs: [
        "https://github.com/phosphor-works",
        "https://github.com/fuddlesworth",
    ],
};
const extra = jsonLd
    ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
    : [];
const ldGraph = {
    "@context": "https://schema.org",
    "@graph": [organization, ...extra],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />

    {/* Favicons served as SVGs (one file renders at any size).  Two
        variants with prefers-color-scheme so the icon reads whether
        the browser chrome is dark or light; /favicon.svg is the plain
        fallback for browsers that don't honor media= on icon links. */}
    <link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon-light.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph — consumed by Mastodon, LinkedIn, Discord, Slack.
        Every page inherits the /og-image.svg brand card; individual
        pages can override via the `ogImage` prop. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Phosphor" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter card.  `summary_large_image` renders the OG image at
        full width rather than the tiny square thumbnail. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />

    {/* Browser chrome tint.  Dark value is the default navy surface;
        the light-mode value matches the palette page's light surface
        background so system-themed UIs don't flash the wrong color
        under the URL bar. */}
    <meta name="theme-color" content="#070F22" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#F8FAFC" media="(prefers-color-scheme: light)" />

    {/* Structured data graph.  set:html preserves exact JSON without
        Astro's auto-escaping chewing on the @ signs. */}
    <script type="application/ld+json" set:html={JSON.stringify(ldGraph)} />

    {/* Pre-paint theme init.  Must run synchronously before <body>
        so the tree renders at the right colors on first paint.
        Reads localStorage (explicit user choice) then falls back to
        prefers-color-scheme.  `is:inline` keeps it un-bundled and
        un-deferred — inline-script FOUC prevention is its whole job. */}
    <script is:inline>
        (() => {
            try {
                const stored = localStorage.getItem("phosphor-theme");
                const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
                const theme = (stored === "dark" || stored === "light")
                    ? stored
                    : (prefersLight ? "light" : "dark");
                document.documentElement.dataset.theme = theme;
            } catch (e) {
                document.documentElement.dataset.theme = "dark";
            }
        })();
    </script>

    <slot name="head" />
</head>
<body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    {/* Copy-button injection.  Attaches to every <pre> after DOM load
        regardless of whether the page uses syntax highlighting. */}
    <script>
        import "../scripts/copy-code";
    </script>
</body>
</html>
